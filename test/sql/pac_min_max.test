# name: test/sql/pac_min_max.test
# description: Test priv_min and priv_max aggregate functions
# group: [sql]

require privacy

statement ok
PRAGMA clear_privacy_metadata;

# Set deterministic seed for cross-CPU reproducibility
statement ok
SET privacy_seed = 42

statement ok
SET pac_hash_repair = true

statement ok
SET threads = 1

statement ok
SET pac_mi = 0

# =============================================================================
# priv_max tests
# =============================================================================

# Test priv_max with TINYINT (INT8)
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::tinyint) FROM range(1, 50) t(i);
----
48

# Test priv_max with SMALLINT (INT16)
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::smallint) FROM range(1, 100) t(i);
----
97

# Test priv_max with INTEGER (INT32)
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::integer) FROM range(1, 100) t(i);
----
97

# Test priv_max with BIGINT (INT64)
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::bigint) FROM range(1, 100) t(i);
----
97

# Test priv_max with UTINYINT (UINT8)
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::utinyint) FROM range(1, 50) t(i);
----
48

# Test priv_max with USMALLINT (UINT16)
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::usmallint) FROM range(1, 100) t(i);
----
97

# Test priv_max with UINTEGER (UINT32)
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::uinteger) FROM range(1, 100) t(i);
----
97

# Test priv_max with UBIGINT (UINT64)
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::ubigint) FROM range(1, 100) t(i);
----
97

# Test priv_max with FLOAT
query R
SELECT round(priv_noised_max(priv_hash(hash('key' || i::varchar)), i::float), 1) FROM range(1, 100) t(i);
----
97.0

# Test priv_max with DOUBLE
query R
SELECT round(priv_noised_max(priv_hash(hash('key' || i::varchar)), i::double), 1) FROM range(1, 100) t(i);
----
97.0

# Test priv_max with negative values (signed types)
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::integer) FROM range(-50, 50) t(i);
----
48

# Test priv_max with non-zero mi parameter (deterministic results due to privacy_seed)
statement ok
SET pac_mi = 128

query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::integer) IS NOT NULL FROM range(1, 100) t(i);
----
true

statement ok
SET pac_mi = 0

# Test priv_max with mi parameter (0.0 for no noise)
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::integer) FROM range(1, 100) t(i);
----
97

# =============================================================================
# priv_min tests
# =============================================================================

# Test priv_min with TINYINT (INT8)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), i::tinyint) FROM range(1, 50) t(i);
----
4

# Test priv_min with SMALLINT (INT16)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), i::smallint) FROM range(1, 100) t(i);
----
4

# Test priv_min with INTEGER (INT32)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), i::integer) FROM range(1, 100) t(i);
----
4

# Test priv_min with BIGINT (INT64)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), i::bigint) FROM range(1, 100) t(i);
----
4

# Test priv_min with UTINYINT (UINT8)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), i::utinyint) FROM range(1, 50) t(i);
----
4

# Test priv_min with USMALLINT (UINT16)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), i::usmallint) FROM range(1, 100) t(i);
----
4

# Test priv_min with UINTEGER (UINT32)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), i::uinteger) FROM range(1, 100) t(i);
----
4

# Test priv_min with UBIGINT (UINT64)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), i::ubigint) FROM range(1, 100) t(i);
----
4

# Test priv_min with FLOAT
query R
SELECT round(priv_noised_min(priv_hash(hash('key' || i::varchar)), i::float), 1) FROM range(1, 100) t(i);
----
4.0

# Test priv_min with DOUBLE
query R
SELECT round(priv_noised_min(priv_hash(hash('key' || i::varchar)), i::double), 1) FROM range(1, 100) t(i);
----
4.0

# Test priv_min with negative values (signed types)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), i::integer) FROM range(-50, 50) t(i);
----
-49

# Test priv_min with mi parameter (0.0 for deterministic results)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), i::integer) FROM range(1, 100) t(i);
----
4

# =============================================================================
# GROUP BY tests
# =============================================================================

# Test priv_max with GROUP BY (mi=0 returns actual values, not NULL)
query II rowsort
SELECT i % 3 as grp, priv_noised_max(priv_hash(hash('key' || i::varchar)), i::integer)
FROM range(1, 100) t(i)
GROUP BY grp;
----
0	96
1	97
2	92

# Test priv_min with GROUP BY (mi=0 returns actual values, not NULL)
query II rowsort
SELECT i % 3 as grp, priv_noised_min(priv_hash(hash('key' || i::varchar)), i::integer)
FROM range(1, 100) t(i)
GROUP BY grp;
----
0	6
1	4
2	11

# =============================================================================
# Edge cases
# =============================================================================

# Test with single value (mi=0 returns actual value)
query I
SELECT priv_noised_max(1::UBIGINT, 42::integer);
----
42

query I
SELECT priv_noised_min(1::UBIGINT, 42::integer);
----
42

# Test with large values (BIGINT)
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), (i * 1000000000)::bigint) FROM range(1, 100) t(i);
----
96999997440

query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), (i * 1000000000)::bigint) FROM range(1, 100) t(i);
----
4000000000

# Test with small range
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::integer) FROM range(1, 10) t(i);
----
9

# Test with scaled values
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), (i * 100)::integer) FROM range(1, 10) t(i);
----
900

# Test with larger scaled values
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), (i * 100000)::integer) FROM range(1, 10) t(i);
----
900000

# Test float with scaling
query R
SELECT round(priv_noised_max(priv_hash(hash('key' || i::varchar)), (i * 100.0)::double), 1) FROM range(1, 100) t(i);
----
9700.0

query R
SELECT round(priv_noised_min(priv_hash(hash('key' || i::varchar)), (i * 100.0)::double), 1) FROM range(1, 100) t(i);
----
400.0

# Test double with large values
query R
SELECT round(priv_noised_max(priv_hash(hash('key' || i::varchar)), (i * 2000000.0)::double), 0) FROM range(1, 100) t(i);
----
194000000.0

query R
SELECT round(priv_noised_min(priv_hash(hash('key' || i::varchar)), (i * 2000000.0)::double), 0) FROM range(1, 100) t(i);
----
8000000.0

# =============================================================================
# HUGEINT tests
# =============================================================================

# Test priv_max with HUGEINT
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::hugeint) FROM range(1, 100) t(i);
----
97

# Test priv_min with HUGEINT
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), i::hugeint) FROM range(1, 100) t(i);
----
4

# Test priv_max with large HUGEINT values (multiplied by large factor)
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), (i::hugeint * 10000000000000::hugeint)) FROM range(1, 100) t(i);
----
969999975972864

# Test priv_min with large HUGEINT values
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), (i::hugeint * 10000000000000::hugeint)) FROM range(1, 100) t(i);
----
39999999311872

# Test priv_max with negative HUGEINT values
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::hugeint) FROM range(-50, 50) t(i);
----
48

# Test priv_min with negative HUGEINT values
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), i::hugeint) FROM range(-50, 50) t(i);
----
-49

