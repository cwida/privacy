# UHUGEINT tests
# =============================================================================

# Test priv_max with UHUGEINT
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), i::uhugeint) FROM range(1, 100) t(i);
----
97

# Test priv_min with UHUGEINT
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), i::uhugeint) FROM range(1, 100) t(i);
