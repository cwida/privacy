4

# Test priv_max with large UHUGEINT values
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), (i::uhugeint * 10000000000000::uhugeint)) FROM range(1, 100) t(i);
----
969999975972864

# Test priv_min with large UHUGEINT values
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), (i::uhugeint * 10000000000000::uhugeint)) FROM range(1, 100) t(i);
----
39999999311872

# =============================================================================
# DATE tests
# =============================================================================

# Test priv_max with DATE
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), ('2020-01-01'::date + i::integer)::date) FROM range(1, 100) t(i);
----
2020-04-07

# Test priv_min with DATE
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), ('2020-01-01'::date + i::integer)::date) FROM range(1, 100) t(i);
----
2020-01-05

# =============================================================================
# TIME tests
# =============================================================================

# Test priv_max with TIME
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), ('00:00:00'::time + (i * interval '1 minute'))::time) FROM range(1, 100) t(i);
----
01:37:00.000256

# Test priv_min with TIME
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), ('00:00:00'::time + (i * interval '1 minute'))::time) FROM range(1, 100) t(i);
----
00:04:00

# =============================================================================
# TIMESTAMP tests
# =============================================================================

# Test priv_max with TIMESTAMP
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), ('2020-01-01 00:00:00'::timestamp + (i * interval '1 day'))::timestamp) FROM range(1, 100) t(i);
----
2020-04-06 23:59:50.194176

# Test priv_min with TIMESTAMP
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), ('2020-01-01 00:00:00'::timestamp + (i * interval '1 day'))::timestamp) FROM range(1, 100) t(i);
----
2020-01-04 23:59:37.472

# =============================================================================
# TIMESTAMP WITH TIME ZONE tests
# =============================================================================

# Test priv_max with TIMESTAMPTZ
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), (('2020-01-01 00:00:00'::timestamp + (i * interval '1 day'))::timestamptz)) FROM range(1, 100) t(i);
----
2020-04-06 23:59:50.194176+00

# Test priv_min with TIMESTAMPTZ
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), (('2020-01-01 00:00:00'::timestamp + (i * interval '1 day'))::timestamptz)) FROM range(1, 100) t(i);
----
2020-01-04 23:59:37.472+00

# =============================================================================
# DECIMAL tests
# =============================================================================

# Test priv_max with DECIMAL(4,2) - maps to INT16
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), (i * 0.5)::decimal(4,2)) FROM range(1, 100) t(i);
----
48.50

# Test priv_min with DECIMAL(4,2)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), (i * 0.5)::decimal(4,2)) FROM range(1, 100) t(i);
----
2.00

# Test priv_max with DECIMAL(9,2) - maps to INT32
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), (i * 1.5)::decimal(9,2)) FROM range(1, 100) t(i);
----
145.50

# Test priv_min with DECIMAL(9,2)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), (i * 1.5)::decimal(9,2)) FROM range(1, 100) t(i);
----
6.00

# Test priv_max with DECIMAL(18,2) - maps to INT64
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), (i * 1.5)::decimal(18,2)) FROM range(1, 100) t(i);
----
145.50

# Test priv_min with DECIMAL(18,2)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), (i * 1.5)::decimal(18,2)) FROM range(1, 100) t(i);
----
6.00

# Test priv_max with DECIMAL(38,2) - maps to HUGEINT
query I
SELECT priv_noised_max(priv_hash(hash('key' || i::varchar)), (i * 1.5)::decimal(38,2)) FROM range(1, 100) t(i);
----
145.50

# Test priv_min with DECIMAL(38,2)
query I
SELECT priv_noised_min(priv_hash(hash('key' || i::varchar)), (i * 1.5)::decimal(38,2)) FROM range(1, 100) t(i);
----
6.00

# ============================================================================
# Sample diversity check tests
# ============================================================================

# Ungrouped priv_max: all rows hash to the same privacy unit → should trigger diversity error
statement error
SELECT priv_noised_max(hash(5)::UBIGINT, 1.0) FROM range(1000) t(i)
----
detected absence of sample diversity

# Grouped priv_max: each group has rows from the same privacy unit → should trigger diversity error
statement error
SELECT key, priv_noised_max(hash(5)::UBIGINT, 1.0) FROM (SELECT i % 3 AS key FROM range(3000) t(i)) sub GROUP BY key
----
detected absence of sample diversity

# Ungrouped priv_min: all rows hash to the same privacy unit → should trigger diversity error
statement error
SELECT priv_noised_min(hash(5)::UBIGINT, 1.0) FROM range(1000) t(i)
----
detected absence of sample diversity

# Grouped priv_min: each group has rows from the same privacy unit → should trigger diversity error
statement error
SELECT key, priv_noised_min(hash(5)::UBIGINT, 1.0) FROM (SELECT i % 3 AS key FROM range(3000) t(i)) sub GROUP BY key
----
detected absence of sample diversity

# Cleanup PAC metadata at end of test
statement ok
PRAGMA clear_privacy_metadata;
