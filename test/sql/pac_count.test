# name: test/sql/pac_count.test
# description: Test as_count aggregate function
# group: [sql]

require privacy

statement ok
PRAGMA clear_privacy_metadata;

statement ok
PRAGMA enable_verification

# Set deterministic seed for cross-CPU reproducibility
statement ok
SET privacy_seed = 42

statement ok
SET pac_hash_repair = true

statement ok
SET threads = 1

statement ok
SET pac_mi = 0

# Create test data with 4000 rows
# rowid from 0-3999, value is rowid % 3 (so values 0, 1, 2)
statement ok
CREATE TABLE test_data AS
SELECT i AS rowid, i % 3 AS value
FROM range(4000) t(i)

# Ungrouped as_count - should return variance of 64 bit counters
query I
SELECT as_noised_count(hash(rowid)::UBIGINT, 1) IS NOT NULL FROM test_data
----
true

# Verify ungrouped as_count returns a bigint
query I
SELECT typeof(as_noised_count(hash(rowid)::UBIGINT, 1)) FROM test_data
----
BIGINT

# Test with non-zero mi parameter (deterministic results due to privacy_seed)
statement ok
SET pac_mi = 128

query I
SELECT as_noised_count(hash(rowid)::UBIGINT, 1) IS NOT NULL FROM test_data
----
true

statement ok
SET pac_mi = 0

# Test with explicit mi parameter (0.0 for no noise)
query I
SELECT as_noised_count(hash(rowid)::UBIGINT, 1) IS NOT NULL FROM test_data
----
true

# Grouped as_count by value (0, 1, 2)
# Each group has ~1333 rows
query II
SELECT value, as_noised_count(hash(rowid)::UBIGINT, 1) IS NOT NULL AS has_result
FROM test_data
GROUP BY value
ORDER BY value
----
0	true
1	true
2	true

# Verify grouped results return bigints
query II
SELECT value, typeof(as_noised_count(hash(rowid)::UBIGINT, 1)) AS result_type
FROM test_data
GROUP BY value
ORDER BY value
----
0	BIGINT
1	BIGINT
2	BIGINT

# Test with NULL values - should be handled correctly
statement ok
CREATE TABLE test_with_nulls AS
SELECT i AS rowid, i % 3 AS value,
       CASE WHEN i % 10 = 0 THEN NULL ELSE hash(i)::UBIGINT END AS key_hash
FROM range(4000) t(i)

query I
SELECT as_noised_count(key_hash, 1) IS NOT NULL FROM test_with_nulls
----
true

# Grouped with NULLs
query II
SELECT value, as_noised_count(key_hash, 1) IS NOT NULL AS has_result
FROM test_with_nulls
GROUP BY value
ORDER BY value
----
0	true
1	true
2	true

# ============================================================
# Test as_noised_count(hash, column, mi) - counts non-null values in column
# ============================================================

# Create table with nullable column (every 3rd row is NULL)
statement ok
CREATE TABLE test_nullable AS
SELECT i AS rowid,
       CASE WHEN i % 3 = 0 THEN NULL ELSE i END AS nullable_col,
       i * 2 AS non_null_col,
       i % 4 AS grp
FROM range(120) t(i)

# Basic column count - should count non-null values only
# 120 rows total, 40 NULLs (every 3rd), so ~80 non-null
query I
SELECT as_noised_count(hash(rowid)::UBIGINT, nullable_col) IS NOT NULL FROM test_nullable
----
true

# Verify return type
query I
SELECT typeof(as_noised_count(hash(rowid)::UBIGINT, nullable_col)) FROM test_nullable
----
BIGINT

# as_count with column should return approximately COUNT(column)
# COUNT(nullable_col) = 80, as_count should be close
query I
SELECT abs(as_noised_count(hash(rowid)::UBIGINT, nullable_col) - COUNT(nullable_col)) < 20 FROM test_nullable
----
true

# Column with no nulls (fast path) - should count all rows
query I
SELECT abs(as_noised_count(hash(rowid)::UBIGINT, non_null_col) - COUNT(non_null_col)) < 20 FROM test_nullable
----
true

# Test with mi parameter: as_noised_count(hash, column, mi)
query I
SELECT as_noised_count(hash(rowid)::UBIGINT, nullable_col) IS NOT NULL FROM test_nullable
----
true

# Grouped as_count with column
query II
SELECT grp, as_noised_count(hash(rowid)::UBIGINT, nullable_col) IS NOT NULL AS has_result
FROM test_nullable
GROUP BY grp
ORDER BY grp
----
0	true
1	true
2	true
3	true

# Grouped count comparison - each group has 30 rows, ~20 non-null
query I
SELECT COUNT(*) = 4 FROM (
    SELECT grp, as_noised_count(hash(rowid)::UBIGINT, nullable_col) AS pc, COUNT(nullable_col) AS c
    FROM test_nullable
    GROUP BY grp
    HAVING abs(pc - c) < 15
)
----
true

# Test all NULLs column - should return NULL (no valid rows counted)
statement ok
CREATE TABLE test_all_nulls AS
SELECT i AS rowid, NULL::INTEGER AS all_null_col FROM range(100) t(i)

query I
SELECT as_noised_count(hash(rowid)::UBIGINT, all_null_col) IS NULL FROM test_all_nulls
----
true

# ============================================================================
# Sample diversity check tests
# ============================================================================

# Ungrouped: all rows hash to the same privacy unit → should trigger diversity error
statement error
SELECT as_noised_count(hash(5)::UBIGINT) FROM range(1000) t(i)
----
detected absence of sample diversity

# Grouped: each group has rows from the same privacy unit → should trigger diversity error
statement error
SELECT key, as_noised_count(hash(5)::UBIGINT) FROM (SELECT i % 3 AS key FROM range(3000) t(i)) sub GROUP BY key
----
detected absence of sample diversity

# Cleanup
statement ok
DROP TABLE test_data

statement ok
DROP TABLE test_with_nulls

statement ok
DROP TABLE test_nullable

statement ok
DROP TABLE test_all_nulls
