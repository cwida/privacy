# name: test/sql/pac_utility_diff.test
# description: Test privacy_diffcols setting with utility summary
# group: [sql]

require privacy

statement ok
PRAGMA clear_privacy_metadata;

statement ok
SET privacy_seed = 42

statement ok
SET pac_hash_repair = true

statement ok
SET threads = 1

statement ok
SET pac_mi = 0

# Create PU table and a child table
statement ok
CREATE PU TABLE diff_pu(
    id INTEGER,
    PRIVACY_KEY (id)
);

statement ok
CREATE TABLE diff_data(
    id INTEGER,
    pu_id INTEGER,
    grp INTEGER,
    val INTEGER
);

statement ok
INSERT INTO diff_pu SELECT i FROM range(50) t(i);

statement ok
INSERT INTO diff_data
SELECT i AS id, (i % 50) AS pu_id, (i % 3) + 1 AS grp,
       CASE WHEN (i % 3) = 0 THEN 10 WHEN (i % 3) = 1 THEN 20 ELSE 30 END AS val
FROM range(300) t(i);

# Add PAC metadata for diff_data
statement ok
ALTER TABLE diff_data ADD PRIVACY_KEY (id);

statement ok
ALTER TABLE diff_data ADD PRIVACY_LINK (pu_id) REFERENCES diff_pu(id);

# ========== Test 1: privacy_diffcols with key-based matching (perfect utility) ==========
# privacy_noise=true but pac_mi=0 means zero noise → utility should be 100%
statement ok
SET privacy_noise = true

statement ok
SET privacy_diffcols = '1'

# grp = key column (shows ref value), total_val = numeric (shows relative error %; 0 = perfect)
query II
SELECT grp, SUM(val) AS total_val FROM diff_data GROUP BY grp ORDER BY grp
----
1	12
2	12
3	12

statement ok
SET privacy_diffcols = NULL

# ========== Test 2: Ungrouped query with positional diff ==========
statement ok
SET privacy_noise = true

statement ok
SET privacy_diffcols = '0'

query I
SELECT SUM(val) AS total_val FROM diff_data
----
12

statement ok
SET privacy_diffcols = NULL

# ========== Test 3: CSV output path ==========
statement ok
SET privacy_noise = true

statement ok
SET privacy_diffcols = '1:/tmp/test_pac_utility.csv'

query II
SELECT grp, SUM(val) AS total_val FROM diff_data GROUP BY grp ORDER BY grp
----
1	12
2	12
3	12

statement ok
SET privacy_diffcols = NULL

# ========== Test 4: Auto-detect key columns (grouped) ==========
statement ok
SET privacy_noise = true

statement ok
SET privacy_diffcols = 'true'

query II
SELECT grp, SUM(val) AS total_val FROM diff_data GROUP BY grp ORDER BY grp
----
1	12
2	12
3	12

statement ok
SET privacy_diffcols = NULL

# ========== Test 5: Auto-detect key columns (ungrouped) ==========
statement ok
SET privacy_noise = true

statement ok
SET privacy_diffcols = 'true'

query I
SELECT SUM(val) AS total_val FROM diff_data
----
12

statement ok
SET privacy_diffcols = NULL

# ========== Test 6: Auto-detect with output path ==========
statement ok
SET privacy_noise = true

statement ok
SET privacy_diffcols = '/tmp/test_pac_utility_auto.csv'

query II
SELECT grp, SUM(val) AS total_val FROM diff_data GROUP BY grp ORDER BY grp
----
1	12
2	12
3	12

statement ok
SET privacy_diffcols = NULL

# ========== Test 7: ORDER BY DESC is preserved in diff output ==========
statement ok
SET privacy_noise = true

statement ok
SET privacy_diffcols = 'true'

query II
SELECT grp, SUM(val) AS total_val FROM diff_data GROUP BY grp ORDER BY grp DESC
----
3	12
2	12
1	12

statement ok
SET privacy_diffcols = NULL

# ========== Cleanup ==========
statement ok
SET privacy_diffcols = NULL

statement ok
PRAGMA clear_privacy_metadata;

statement ok
DROP TABLE diff_data;

statement ok
DROP TABLE diff_pu;
