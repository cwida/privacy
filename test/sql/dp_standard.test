# name: test/sql/dp_standard.test
# description: Standard global-sensitivity DP — per-PU contribution clipping, pure ε-DP Laplace
# group: [sql]

require privacy

statement ok
PRAGMA clear_privacy_metadata;

statement ok
SET privacy_seed = 42;

statement ok
SET threads = 1;

# ---------------------------------------------------------------------------
# dp_standard is selectable via the single privacy_mode setting
# ---------------------------------------------------------------------------

statement ok
SET privacy_mode = 'dp_standard';

query I
SELECT current_setting('privacy_mode');
----
dp_standard

# ---------------------------------------------------------------------------
# Single PU table, no joins: global sensitivity of COUNT(*) is 1 → scale = 1/ε.
# Pure ε-DP, so NO dp_delta is required (unlike dp_elastic).
# ---------------------------------------------------------------------------

statement ok
CREATE TABLE u (id BIGINT, region VARCHAR);

statement ok
INSERT INTO u SELECT i, 'r' || (i % 5) FROM range(100) t(i);

statement ok
ALTER TABLE u ADD PRIVACY_KEY (id);

statement ok
ALTER TABLE u SET PU;

statement ok
SET dp_epsilon = 1.0;

# No dp_delta set — dp_standard must still compile (pure ε-DP).
statement ok
SET dp_delta = NULL;

# 100 samples, scale = 1/ε = 1 → P(|noise| > 50) is astronomically small.
query I
SELECT abs(COUNT(*) - 100) < 50 FROM u;
----
true

# COUNT preserves its original type (BIGINT). Noise is cast back after Laplace.
query I
SELECT typeof(COUNT(*)) FROM u;
----
BIGINT

# With noise disabled the single-table count is exact and needs no bound.
statement ok
SET privacy_noise = false;

query I
SELECT COUNT(*) FROM u;
----
100

# Single-table SUM still requires dp_sum_bound (per-row == per-PU here).
statement ok
SET dp_sum_bound = NULL;

statement error
SELECT SUM(id) FROM u;
----
dp_standard: dp_sum_bound must be set

# ---------------------------------------------------------------------------
# FK join. orders: 500 rows, exactly 5 per user (uid = i % 100).
# Each user u's 5 orders all carry amount = (u % 10), so:
#   per-user count = 5,  per-user sum = 5 * (u % 10)
#   total count = 500,   total sum = 5 * sum_{u}(u%10) = 5 * 450 = 2250
# ---------------------------------------------------------------------------

statement ok
CREATE TABLE orders (uid BIGINT, store VARCHAR, amount DOUBLE);

statement ok
INSERT INTO orders SELECT i % 100, 's' || (i % 4), (i % 10) * 1.0 FROM range(500) t(i);

statement ok
ALTER TABLE orders ADD PRIVACY_LINK (uid) REFERENCES u(id);

statement ok
SET privacy_noise = false;

# COUNT over a join needs dp_count_bound (one PU can own many rows).
statement error
SELECT COUNT(*) FROM orders;
----
dp_standard: dp_count_bound must be set

# Bound >= 5 (the true per-user count) leaves clipping inert → exact 500.
statement ok
SET dp_count_bound = 10.0;

query I
SELECT COUNT(*) FROM orders;
----
500

# Per-PU clipping (NOT per-row): a count bound of 3 clips each user's 5 rows to 3,
# so the total is 100 users * 3 = 300, not 500. This is the defining property.
statement ok
SET dp_count_bound = 3.0;

query I
SELECT COUNT(*) FROM orders;
----
300

statement ok
SET dp_count_bound = 10.0;

# SUM over a join needs dp_sum_bound.
statement ok
SET dp_sum_bound = NULL;

statement error
SELECT SUM(amount) FROM orders;
----
dp_standard: dp_sum_bound must be set

# Large bound leaves clipping inert → exact 2250.
statement ok
SET dp_sum_bound = 1000.0;

query I
SELECT SUM(amount) FROM orders;
----
2250.000000

# FILTER (WHERE ...) on a join must be applied to the per-PU partial, not dropped. Each user's 5
# orders all carry amount = uid % 10, so amount > 5 keeps only the 40 users with uid % 10 in
# {6,7,8,9}: SUM = 5 * (6+7+8+9) * 10 = 1500 (vs 2250 unfiltered).
query I
SELECT SUM(amount) FILTER (WHERE amount > 5) FROM orders;
----
1500.000000

# COUNT(*) FILTER over the same join: 40 users * 5 rows = 200 (vs 500 unfiltered).
query I
SELECT COUNT(*) FILTER (WHERE amount > 5) FROM orders;
----
200

# dp_standard AVG follows Google-style bounded mean shape: clip values into the
# public bounded domain [0, dp_sum_bound], center around the midpoint before
# SUM noise, divide by noised COUNT, then add the midpoint back.
statement ok
CREATE TABLE avg_values (id BIGINT, v DOUBLE);

statement ok
INSERT INTO avg_values VALUES (0, -10.0), (1, 10.0), (2, 200.0);

statement ok
ALTER TABLE avg_values ADD PRIVACY_KEY (id);

statement ok
ALTER TABLE avg_values SET PU;

statement ok
SET dp_sum_bound = 100.0;

query I
SELECT AVG(v) FROM avg_values;
----
36.666667

statement ok
SET dp_sum_bound = 1000.0;

# Per-PU clipping: bound 10 clips each user's sum (= 5*(u%10)) to min(., 10).
# Per residue r in 0..9 (10 users each): min(5r, 10) = [0,5,10,10,10,10,10,10,10,10]
# sum over residues = 85, * 10 users = 850. (Per-ROW clipping would leave 2250.)
statement ok
SET dp_sum_bound = 10.0;

query I
SELECT SUM(amount) FROM orders;
----
850.000000

statement ok
SET dp_count_bound = 3.0;

# For joined AVG, the centered SUM contribution bound is
# dp_count_bound * ((upper - lower) / 2). With bounds [0, 10], that is
# 3 * 5 = 15 per PU, matching Google's bounded-mean calibration.
query I
SELECT AVG(amount) FROM orders;
----
4.500000

statement ok
SET dp_sum_bound = 1000.0;

statement ok
SET dp_count_bound = 10.0;

# Multiple aggregate expressions in the same aggregate node are supported; this is
# one DP release vector with budget split across the user-visible aggregates.
query II
SELECT COUNT(*), SUM(amount) FROM orders;
----
500	2250.000000

# ---------------------------------------------------------------------------
# Partition selection. The released set of group keys is data-dependent, so grouped dp_standard
# queries automatically apply DP partition selection (noised COUNT(DISTINCT pu) ≥ τ, τ computed from
# the budget — private by default, like dp_sass). This makes grouped dp_standard (ε,δ)-DP, so
# dp_delta is required; ungrouped dp_standard stays pure ε-DP.
# ---------------------------------------------------------------------------

statement ok
SET dp_count_bound = 10.0;

# Grouped joins require an L0 group-contribution bound (dp_max_groups_contributed = C_u): one PU may
# affect multiple output groups, and C_u enters both the value sensitivity and the τ formula.
statement error
SELECT store, COUNT(*) FROM orders GROUP BY store;
----
dp_max_groups_contributed

statement ok
SET dp_max_groups_contributed = 4.0;

# Without dp_delta a grouped query is now rejected — partition selection needs δ_η.
statement error
SELECT store, COUNT(*) FROM orders GROUP BY store;
----
dp_delta

statement ok
SET dp_delta = 0.49;

# With a tiny ε the computed τ far exceeds every group's PU support, so all groups are suppressed
# (noise off → deterministic distinct-PU count ≥ τ).
statement ok
SET dp_epsilon = 0.001;

query II
SELECT store, COUNT(*) FROM orders GROUP BY store;
----

statement ok
SET dp_epsilon = 1.0;

# Nested aggregates are not supported: a query may have multiple aggregate
# expressions, but not an aggregate over another aggregate's private output.
statement error
WITH public_bins(order_count) AS (
  SELECT i FROM range(0, 7) t(i)
),
per_user AS (
  SELECT id, least(COUNT(uid), 6) AS order_count
  FROM u
  LEFT JOIN orders ON id = uid
  GROUP BY id
)
SELECT public_bins.order_count, COUNT(per_user.id)
FROM public_bins
LEFT JOIN per_user ON public_bins.order_count = per_user.order_count
GROUP BY public_bins.order_count;
----
dp_standard: CTEs are not supported by DP mechanisms

# L0 contribution bounding: each PU touches all three groups, but max groups is two, so each PU's
# total contribution is capped at 2. Uses enough PUs (40) that the surviving groups clear τ — small
# groups would otherwise be suppressed by partition selection.
statement ok
CREATE TABLE orders_l0 (uid BIGINT, store VARCHAR);

statement ok
INSERT INTO orders_l0 SELECT i, s FROM range(40) t(i), (VALUES ('a'), ('b'), ('c')) v(s);

statement ok
ALTER TABLE orders_l0 ADD PRIVACY_LINK (uid) REFERENCES u(id);

statement ok
SET dp_count_bound = 1.0;

statement ok
SET dp_max_groups_contributed = 2.0;

# Each PU contributes at most 1 per group (count_bound=1) and to at most 2 groups (C_u=2), so the
# total released count across all groups is ≤ 40·2 = 80, never the raw 120 (noise off, dense groups
# survive τ). Exact per-group split is determined by the deterministic per-PU group selection.
query II rowsort
SELECT store, COUNT(*) AS cnt
FROM orders_l0
GROUP BY store;
----
a	18
b	33
c	29

# Public side tables are allowed in Google-style DP. COUNT(DISTINCT) is computed per PU
# before clipping, then summed.
statement ok
CREATE TABLE public_store (store VARCHAR, label VARCHAR);

statement ok
INSERT INTO public_store VALUES ('s0', 'even'), ('s1', 'odd'), ('s2', 'even'), ('s3', 'odd');

statement ok
SET dp_count_bound = 10.0;

statement ok
SET dp_max_groups_contributed = 2.0;

query II rowsort
SELECT public_store.label, COUNT(DISTINCT orders.uid)
FROM orders
JOIN public_store ON orders.store = public_store.store
GROUP BY public_store.label;
----
even	50
odd	50

# Missing FK path tables are joined internally for per-PU clipping. The query
# scans only the leaf table, but the PU key lives on the parent table:
# child_lines -> parent_orders -> users2. The raw leaf count is 9; after grouping
# by user and clipping to 4, the result is min(5,4) + min(4,4) = 8.
statement ok
CREATE TABLE users2 (id BIGINT);

statement ok
INSERT INTO users2 VALUES (0), (1);

statement ok
ALTER TABLE users2 ADD PRIVACY_KEY (id);

statement ok
ALTER TABLE users2 SET PU;

statement ok
CREATE TABLE parent_orders (order_id BIGINT, uid BIGINT);

statement ok
INSERT INTO parent_orders VALUES (10, 0), (11, 0), (20, 1);

statement ok
ALTER TABLE parent_orders ADD PRIVACY_LINK (uid) REFERENCES users2(id);

statement ok
CREATE TABLE child_lines (line_id BIGINT, order_id BIGINT);

statement ok
INSERT INTO child_lines VALUES (1, 10), (2, 10), (3, 10), (4, 11), (5, 11), (6, 20), (7, 20), (8, 20), (9, 20);

statement ok
ALTER TABLE child_lines ADD PRIVACY_LINK (order_id) REFERENCES parent_orders(order_id);

statement ok
SET dp_count_bound = 4.0;

statement ok
SET dp_max_groups_contributed = 1.0;

query I
SELECT COUNT(*) FROM child_lines;
----
8

# Hidden self-joins from EXISTS/NOT EXISTS filters are rejected by the shared
# DP shape checker before mode-specific rewrite logic runs.
statement error
SELECT COUNT(*)
FROM orders_l0 o1
WHERE EXISTS (
  SELECT *
  FROM orders_l0 o2
  WHERE o2.uid = o1.uid
    AND o2.store <> o1.store
);
----
dp_standard: lateral or correlated subqueries are not supported by DP mechanisms

# --- MIN/MAX (dp_standard) ---
# Values are clipped to the public domain [dp_minmax_lower_bound, dp_minmax_upper_bound], so global
# sensitivity is the range U-L; the noised output is clamped back into that domain. dp_elastic rejects
# MIN/MAX (elastic sensitivity is defined only for counting queries — see dp_elastic.test).
statement ok
SET privacy_noise = false;

statement ok
SET dp_minmax_lower_bound = 0.0;

statement ok
SET dp_minmax_upper_bound = 100.0;

# Single table: values -10, 10, 200 clip into [0, 100] → MIN = 0, MAX = 100.
query II
SELECT MIN(v), MAX(v) FROM avg_values;
----
0.0	100.0

# Join: each user's amount is constant (uid % 10); per-PU MIN/MAX = that value, overall MIN = 0,
# MAX = 9 (both inside [0, 100], so clipping is a no-op here).
query II
SELECT MIN(amount), MAX(amount) FROM orders JOIN u ON orders.uid = u.id;
----
0.0	9.0

# MIN/MAX require the domain bounds.
statement ok
SET dp_minmax_upper_bound = NULL;

statement error
SELECT MAX(v) FROM avg_values;
----
dp_minmax_upper_bound must be set

# Lower bound must be strictly below the upper bound.
statement ok
SET dp_minmax_upper_bound = 100.0;

statement ok
SET dp_minmax_lower_bound = 100.0;

statement error
SELECT MIN(v) FROM avg_values;
----
dp_minmax_lower_bound must be smaller than

statement ok
SET dp_minmax_lower_bound = 0.0;

statement ok
SET privacy_noise = true;
