# name: test/sql/dp_reject_unsupported_shapes.test
# description: DP mechanisms reject unsupported CTE/subquery shapes and share case-insensitive FK column lookup
# group: [sql]

require privacy

statement ok
PRAGMA clear_privacy_metadata;

statement ok
SET threads = 1;

statement ok
SET privacy_seed = 42;

statement ok
SET privacy_noise = false;

statement ok
SET dp_epsilon = 1.0;

statement ok
SET dp_delta = 1e-6;

statement ok
SET dp_count_bound = 10;

statement ok
SET dp_sum_bound = 100;

statement ok
SET dp_max_groups_contributed = 10;

statement ok
CREATE TABLE Users (Id BIGINT);

statement ok
CREATE TABLE Posts (OwnerUserId BIGINT, Score INTEGER);

statement ok
INSERT INTO Users VALUES (1), (2);

statement ok
INSERT INTO Posts VALUES (1, 10), (1, 20), (2, 30);

statement ok
ALTER TABLE Users ADD PRIVACY_KEY (Id);

statement ok
ALTER TABLE Users SET PU;

# Metadata can be normalized differently from the physical schema. All DP modes
# should resolve this through the same case-insensitive projection helper.
statement ok
ALTER TABLE Posts ADD PRIVACY_LINK (owneruserid) REFERENCES Users(Id);

statement ok
SET privacy_mode = 'dp_standard';

query I
SELECT COUNT(*) FROM Posts p JOIN Users u ON p.OwnerUserId = u.Id;
----
3

statement ok
SET privacy_mode = 'dp_standard';

statement error
WITH p AS (SELECT * FROM Posts)
SELECT COUNT(*) FROM p;
----
dp_standard: CTEs are not supported by DP mechanisms

statement ok
SET privacy_mode = 'dp_elastic';

statement error
WITH p AS (SELECT * FROM Posts)
SELECT COUNT(*) FROM p;
----
dp_elastic: CTEs are not supported by DP mechanisms

statement ok
SET privacy_mode = 'dp_sass';

statement error
WITH p AS (SELECT * FROM Posts)
SELECT COUNT(*) FROM p;
----
dp_sass: CTEs are not supported by DP mechanisms

statement ok
SET privacy_mode = 'dp_standard';

statement error
SELECT COUNT(*) FROM Posts WHERE OwnerUserId IN (SELECT Id FROM Users);
----
subqueries are not supported by DP mechanisms

statement ok
SET privacy_mode = 'dp_elastic';

statement error
SELECT COUNT(*) FROM Posts WHERE OwnerUserId IN (SELECT Id FROM Users);
----
subqueries are not supported by DP mechanisms

statement ok
SET privacy_mode = 'dp_sass';

statement error
SELECT COUNT(*) FROM Posts WHERE OwnerUserId IN (SELECT Id FROM Users);
----
subqueries are not supported by DP mechanisms
