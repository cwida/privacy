# ============================================================================
# Test 23: INSERT from derived_pu into plain table (finalizes on read)
# Tests: When inserting finalized values into a non-derived_pu table,
# the implicit cast finalizes counter columns to scalars.
# ============================================================================

statement ok
CREATE PU TABLE ins_src (id INT, grp INT, val INT, PRIVACY_KEY(id), PROTECTED(val));

statement ok
INSERT INTO ins_src VALUES (1,1,10),(2,1,20),(3,2,100),(4,2,200);

statement ok
CREATE TABLE mv_ins AS SELECT grp, SUM(val) AS total FROM ins_src GROUP BY grp;

statement ok
CREATE TABLE plain_copy (grp INT, val DOUBLE);

# INSERT into plain table from derived_pu — total should be finalized
statement ok
INSERT INTO plain_copy SELECT grp, total FROM mv_ins;

query I
SELECT COUNT(*) FROM plain_copy;
----
2

# Values should be scalars, not lists
query I
SELECT COUNT(*) FROM plain_copy WHERE val > 0;
----
2

statement ok
DROP TABLE plain_copy;

statement ok
DROP TABLE mv_ins;

statement ok
DROP TABLE ins_src;

# ============================================================================
# Test 24: NOT EQUAL on counter column
# Tests: The != operator on counter columns works via the equality binder path.
# ============================================================================

statement ok
CREATE PU TABLE neq_src (id INT, grp INT, val INT, PRIVACY_KEY(id), PROTECTED(val));

statement ok
INSERT INTO neq_src VALUES (1,1,10),(2,1,20),(3,2,100),(4,2,200),(5,3,5);

statement ok
CREATE TABLE mv_neq AS SELECT grp, SUM(val) AS total FROM neq_src GROUP BY grp;

# All noised totals should be != 0. priv_filter_neq uses majority voting:
# even grp=3 (single PU, exact sum=5) has 32/64 subsamples with non-zero counters.
query I
SELECT COUNT(*) FROM mv_neq WHERE total != 0;
----
3

statement ok
DROP TABLE mv_neq;

statement ok
DROP TABLE neq_src;

# ============================================================================
# Test 25: NULLIF on counter column
# Tests: NULLIF compares counter column to a value, returning NULL on match.
# ============================================================================

statement ok
CREATE PU TABLE nif_src (id INT, grp INT, val INT, PRIVACY_KEY(id), PROTECTED(val));

statement ok
INSERT INTO nif_src VALUES (1,1,10),(2,1,20),(3,2,100),(4,2,200),(5,3,5);

statement ok
CREATE TABLE mv_nif AS SELECT grp, SUM(val) AS total FROM nif_src GROUP BY grp;

# NULLIF(total, 0) should return NULL for 0-valued totals, non-null otherwise.
# All 3 groups have non-zero true sums; pac_filter_<cmp> majority voting keeps them all.
query I
SELECT COUNT(*) FROM mv_nif WHERE NULLIF(total, 0) IS NOT NULL;
----
3

statement ok
DROP TABLE mv_nif;

statement ok
DROP TABLE nif_src;

# Cleanup
statement ok
PRAGMA clear_privacy_metadata;
