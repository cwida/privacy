statement ok
CREATE TABLE mv_u2 AS SELECT grp, SUM(val) AS total FROM union_src GROUP BY grp;

# UNION ALL should produce 4 rows (2 from each)
query I
SELECT COUNT(*) FROM (SELECT total FROM mv_u1 UNION ALL SELECT total FROM mv_u2);
