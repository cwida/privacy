# name: test/sql/dp_elastic.test
# description: Elastic-sensitivity DP mode — Phase A: plumbing only
# group: [sql]

require privacy

statement ok
PRAGMA clear_privacy_metadata;

statement ok
SET privacy_seed = 42;

statement ok
SET threads = 1;

# ---------------------------------------------------------------------------
# Phase A: defaults and settings registration
# ---------------------------------------------------------------------------

# Default privacy_mode is 'pac'
query I
SELECT current_setting('privacy_mode');
----
pac

# Default dp_epsilon is 1.0
query I
SELECT current_setting('dp_epsilon');
----
1.0

# Settings are writable
statement ok
SET privacy_mode = 'dp_elastic';

query I
SELECT current_setting('privacy_mode');
----
dp_elastic

statement ok
SET dp_epsilon = 0.5;

statement ok
SET dp_sum_bound = 100.0;

# ---------------------------------------------------------------------------
# priv_laplace_noise scalar UDF works standalone
# ---------------------------------------------------------------------------

statement ok
SET privacy_mode = 'pac';

# Scale 0 returns value unchanged
query I
SELECT priv_laplace_noise(100.0, 0.0);
----
100.0

# Old SQL-visible dp_* helper names are intentionally not registered.
statement error
SELECT dp_laplace_noise(100.0, 0.0);
----
dp_laplace_noise

# Non-zero scale produces a noised value (exact value is seed-dependent, just check it's finite)
query I
SELECT abs(priv_laplace_noise(100.0, 5.0) - 100.0) < 1000;
----
true

# ---------------------------------------------------------------------------
# dp_elastic dispatch reaches the stub (Phase A: NotImplemented)
# ---------------------------------------------------------------------------

statement ok
CREATE TABLE u (id BIGINT, region VARCHAR);

statement ok
INSERT INTO u SELECT i, 'r' || (i % 5) FROM range(100) t(i);

statement ok
ALTER TABLE u ADD PRIVACY_KEY (id);

statement ok
ALTER TABLE u SET PU;

statement ok
ALTER PU TABLE u ADD PROTECTED (region);

statement ok
SET privacy_mode = 'dp_elastic';

statement ok
SET dp_epsilon = 1.0;

statement ok
PRAGMA refresh_dp_stats(1.0);

query I
SELECT current_setting('dp_epsilon');
----
1.0

query I
SELECT current_setting('dp_delta')::DOUBLE > 0 AND current_setting('dp_delta')::DOUBLE < 0.5;
----
true

statement ok
SET dp_delta = 0.49;

# ---------------------------------------------------------------------------
# Phase B: COUNT(*) on a single PU table, no joins
# ---------------------------------------------------------------------------

# Smooth elastic sensitivity with no joins gives ES=2, so scale = 2/ε.
# 100 samples → P(|noise| > 50) is astronomically small.
query I
SELECT abs(COUNT(*) - 100) < 50 FROM u;
----
true

# COUNT preserves its original type (BIGINT). Noise is cast back after Laplace.
query I
SELECT typeof(COUNT(*)) FROM u;
----
BIGINT

# With very small epsilon, noise is large but still finite
statement ok
SET dp_epsilon = 0.01;

query I
SELECT COUNT(*) IS NOT NULL AND COUNT(*) < 1000000 FROM u;
----
true

statement ok
SET dp_epsilon = 1.0;

# ---------------------------------------------------------------------------
# Phase B: FK join setup (orders: 500 rows, 5 orders per user → mf_K = 5)
# ---------------------------------------------------------------------------

statement ok
CREATE TABLE orders (uid BIGINT, amount DOUBLE);

statement ok
INSERT INTO orders SELECT i % 100, (i % 7)*1.0 FROM range(500) t(i);

statement ok
ALTER TABLE orders ADD PRIVACY_LINK (uid) REFERENCES u(id);

statement ok
RESET dp_delta;

statement error
SELECT COUNT(*) FROM u JOIN orders ON u.id = orders.uid;
----
dp_delta must be set

statement ok
SET dp_delta = 0.49;

# ---------------------------------------------------------------------------
# Phase C: SUM with dp_sum_bound clipping on a single PU table
# ---------------------------------------------------------------------------

# SUM requires dp_sum_bound — error if unset
statement ok
RESET dp_sum_bound;

statement error
SELECT SUM(id) FROM u;
----
dp_sum_bound

# With bound set: query succeeds, result is noised around true sum
# True sum of 0..99 = 4950. Clip at 100 → per-tuple contribution ≤ 100.
# Noise scale = 100/1 = 100, std-dev = 100·√2 ≈ 141. Allow generous slack.
statement ok
SET dp_sum_bound = 100.0;

query I
SELECT abs(SUM(id) - 4950) < 2000 FROM u;
----
true

# Output type preserved (HUGEINT for sum of BIGINT)
query I
SELECT typeof(SUM(id)) FROM u;
----
HUGEINT

# Clipping takes effect: with bound=5, per-tuple contribution ≤ 5 → max sum ≤ 5 * 100 = 500
# True unclipped sum is 4950; clipped sum should be ~500. Allow noise slack.
statement ok
SET dp_sum_bound = 5.0;

query I
SELECT abs(SUM(id) - 500) < 500 FROM u;
----
true

# Negative values are clipped to -C
statement ok
CREATE TABLE signed_u (id BIGINT, v BIGINT);

statement ok
INSERT INTO signed_u SELECT i, CASE WHEN i % 2 = 0 THEN 1000 ELSE -1000 END FROM range(100) t(i);

statement ok
ALTER TABLE signed_u ADD PRIVACY_KEY (id);

statement ok
ALTER TABLE signed_u SET PU;

statement ok
SET dp_sum_bound = 10.0;

# True sum = 0 (balanced +1000/-1000). Clipped contribution is ±10.
# Noise scale = 10/1 = 10, std-dev ≈ 14. Sum should stay near 0.
query I
SELECT abs(SUM(v)) < 200 FROM signed_u;
----
true

# MIN still rejected
statement error
SELECT MIN(id) FROM u;
----
only COUNT, SUM, and AVG

# ---------------------------------------------------------------------------
# Phase D: FK joins — elastic sensitivity = product of mf_K along chain
# ---------------------------------------------------------------------------

statement ok
SET dp_epsilon = 1.0;

# orders: 500 rows, uid = i % 100 → each user has exactly 5 orders → mf_K = 5
# ES = 5, scale = 5/1.0 = 5, noise std ≈ 7. True COUNT = 500. Allow large slack.
query I
SELECT abs(COUNT(*) - 500) < 500 FROM u JOIN orders ON u.id = orders.uid;
----
true

# COUNT type preserved (BIGINT) even after Laplace + cast
query I
SELECT typeof(COUNT(*)) FROM u JOIN orders ON u.id = orders.uid;
----
BIGINT

# SUM with join: amount values in 0..6, all < dp_sum_bound=10 → no clipping
# True sum = 500 * avg(0..6) = 500 * 3 = 1500
# scale = 5 * 10 / 1.0 = 50, noise std ≈ 70. Allow 1000 slack.
statement ok
SET dp_sum_bound = 10.0;

query I
SELECT abs(SUM(amount) - 1500) < 1000 FROM u JOIN orders ON u.id = orders.uid;
----
true

# SUM output type preserved (DOUBLE for sum of DOUBLE)
query I
SELECT typeof(SUM(amount)) FROM u JOIN orders ON u.id = orders.uid;
----
DOUBLE

# Star/diamond joins rejected: reviews also links directly to u,
# making it a star (u ← orders, u ← reviews) not a linear chain
statement ok
CREATE TABLE reviews (uid BIGINT, score INT);

statement ok
INSERT INTO reviews SELECT i % 100, i % 5 FROM range(200) t(i);

statement ok
ALTER TABLE reviews ADD PRIVACY_LINK (uid) REFERENCES u(id);

statement error
SELECT COUNT(*) FROM u JOIN orders ON u.id = orders.uid JOIN reviews ON u.id = reviews.uid;
----
star/diamond

# ---------------------------------------------------------------------------
# Phase D: 2-hop FK chain — mf_K multiplicativity
# customers2 ← customer_orders (mf_K=5) ← order_lines (mf_K=3) → ES = 15
# ---------------------------------------------------------------------------

statement ok
CREATE TABLE customers2 (cust_id BIGINT);

statement ok
INSERT INTO customers2 SELECT i FROM range(50) t(i);

statement ok
ALTER TABLE customers2 ADD PRIVACY_KEY (cust_id);

statement ok
ALTER TABLE customers2 SET PU;

statement ok
CREATE TABLE customer_orders (ord_id BIGINT, cust_id BIGINT);

statement ok
INSERT INTO customer_orders SELECT i, i % 50 FROM range(250) t(i);

statement ok
ALTER TABLE customer_orders ADD PRIVACY_KEY (ord_id);

statement ok
ALTER TABLE customer_orders ADD PRIVACY_LINK (cust_id) REFERENCES customers2(cust_id);

statement ok
CREATE TABLE order_lines (line_id BIGINT, ord_id BIGINT, price DOUBLE);

statement ok
INSERT INTO order_lines SELECT i, i % 250, (i % 5) * 1.0 FROM range(750) t(i);

statement ok
ALTER TABLE order_lines ADD PRIVACY_KEY (line_id);

statement ok
ALTER TABLE order_lines ADD PRIVACY_LINK (ord_id) REFERENCES customer_orders(ord_id);

statement ok
SET dp_epsilon = 1.0;
RESET dp_sum_bound;

# ES = 5 * 3 = 15, scale = 15, noise std ≈ 21. True COUNT = 750. Allow 1500 slack.
query I
SELECT abs(COUNT(*) - 750) < 1500
FROM customers2
JOIN customer_orders ON customers2.cust_id = customer_orders.cust_id
JOIN order_lines ON customer_orders.ord_id = order_lines.ord_id;
----
true

# ---------------------------------------------------------------------------
# Phase E: smooth elastic sensitivity (dp_delta → (ε, δ)-DP)
# ---------------------------------------------------------------------------

# Single PU, no joins: mf_values=[], SES_β=1.0 → ES = 2*1.0 = 2.0 → scale = 2.0/ε
statement ok
SET dp_delta = 1e-6;
SET dp_epsilon = 1.0;

query I
SELECT COUNT(*) IS NOT NULL AND abs(COUNT(*) - 100) < 300 FROM u;
----
true

# 1-hop join: mf_K=5, β=ε/(2·ln(2/δ))≈0.034 → SES≈13 → ES=2*13=26 → very noisy but finite
query I
SELECT COUNT(*) IS NOT NULL AND COUNT(*) < 100000 FROM u JOIN orders ON u.id = orders.uid;
----
true

statement ok
SET dp_delta = 1e-6;

# ---------------------------------------------------------------------------
# Utility comparison: privacy_diffcols with dp_elastic
# ---------------------------------------------------------------------------

# Very high epsilon → Laplace scale ≈ 0 → COUNT unchanged after BIGINT cast → 0% error
# privacy_diffcols='0' uses positional matching (suitable for ungrouped aggregates)
statement ok
SET dp_epsilon = 10000.0;
SET privacy_diffcols = '0';

# 100 rows, COUNT(*) = 100. Noise ≈ 0 at epsilon=10000 → error% = 0.
query I
SELECT COUNT(*) FROM u;
----
0

statement ok
SET privacy_diffcols = NULL;
SET dp_epsilon = 1.0;

# ---------------------------------------------------------------------------
# Deterministic tests — privacy_noise = false (zero Laplace scale, exact results)
# Mirrors pac_mi = 0 in PAC mode: compilation pipeline runs (clipping, FK chain,
# sensitivity) but Laplace scale is forced to 0 → output is the exact aggregate.
# ---------------------------------------------------------------------------

statement ok
SET privacy_noise = false;

# Exact COUNT
query I
SELECT COUNT(*) FROM u;
----
100

query I
SELECT typeof(COUNT(*)) FROM u;
----
BIGINT

# SUM no clipping (bound=100 > max id=99): 0+1+…+99 = 4950
statement ok
SET dp_sum_bound = 100.0;

query I
SELECT SUM(id) FROM u;
----
4950

query I
SELECT typeof(SUM(id)) FROM u;
----
HUGEINT

# SUM with clipping at 5: ids 0..4 contribute 0+1+2+3+4=10; ids 5..99 each contribute 5 (95 rows=475) → 485
statement ok
SET dp_sum_bound = 5.0;

query I
SELECT SUM(id) FROM u;
----
485

# Symmetric clipping: v=±1000 clipped to ±10 → sum = 50*(+10) + 50*(-10) = 0
statement ok
SET dp_sum_bound = 10.0;

query I
SELECT SUM(v) FROM signed_u;
----
0

# 1-hop JOIN COUNT: 500 orders (5 per user × 100 users)
statement ok
RESET dp_sum_bound;

query I
SELECT COUNT(*) FROM u JOIN orders ON u.id = orders.uid;
----
500

# 1-hop JOIN SUM no clipping (amount 0..6, bound=10): true sum = 1494
statement ok
SET dp_sum_bound = 10.0;

query I
SELECT SUM(amount) FROM u JOIN orders ON u.id = orders.uid;
----
1494.0

# 1-hop JOIN SUM with clipping (bound=3): values 4,5,6 → 3; per 7-cycle: 0+1+2+3+3+3+3=15;
# 71 full cycles = 1065; remaining (i%7 for i=497,498,499) = 0+1+2 = 3; total = 1068
statement ok
SET dp_sum_bound = 3.0;

query I
SELECT SUM(amount) FROM u JOIN orders ON u.id = orders.uid;
----
1068.0

# 2-hop chain COUNT: 750 order_lines (3 per order × 250 orders)
statement ok
RESET dp_sum_bound;

query I
SELECT COUNT(*) FROM customers2
JOIN customer_orders ON customers2.cust_id = customer_orders.cust_id
JOIN order_lines ON customer_orders.ord_id = order_lines.ord_id;
----
750

# 2-hop SUM: price = (i%5)*1.0 for i=0..749; values 0..4 all ≤ bound=5 (no clipping)
# 750/5=150 cycles × (0+1+2+3+4)=10 → 1500.0
statement ok
SET dp_sum_bound = 5.0;

query I
SELECT SUM(price) FROM customers2
JOIN customer_orders ON customers2.cust_id = customer_orders.cust_id
JOIN order_lines ON customer_orders.ord_id = order_lines.ord_id;
----
1500.0

# privacy_diffcols with privacy_noise=false: exact match → error% = 0
statement ok
SET privacy_diffcols = '0';
RESET dp_sum_bound;

query I
SELECT COUNT(*) FROM u;
----
0

statement ok
SET privacy_diffcols = NULL;

# ---------------------------------------------------------------------------
# Implicit FK chain: PU table not in FROM clause (no explicit join required)
# Sensitivity is derived from PRIVACY_LINK metadata; result equals explicit-join version.
# ---------------------------------------------------------------------------

statement ok
RESET dp_sum_bound;

# 1-hop COUNT without joining u — same result as FROM u JOIN orders
query I
SELECT COUNT(*) FROM orders;
----
500

# 1-hop SUM without joining u — same result as FROM u JOIN orders (no clipping)
statement ok
SET dp_sum_bound = 10.0;

query I
SELECT SUM(amount) FROM orders;
----
1494.0

# 1-hop SUM with clipping without joining u — same as explicit-join version
statement ok
SET dp_sum_bound = 3.0;

query I
SELECT SUM(amount) FROM orders;
----
1068.0

# 2-hop COUNT without any joins — same result as full explicit join chain
statement ok
RESET dp_sum_bound;

query I
SELECT COUNT(*) FROM order_lines;
----
750

# 2-hop SUM without any joins — same result as full explicit join chain
statement ok
SET dp_sum_bound = 5.0;

query I
SELECT SUM(price) FROM order_lines;
----
1500.0

# Table with no privacy metadata is inconspicuous — passes through unmodified
statement ok
CREATE TABLE no_link_table (x INTEGER);

statement ok
INSERT INTO no_link_table VALUES (1), (2), (3);

query I
SELECT COUNT(*) FROM no_link_table;
----
3

statement ok
DROP TABLE no_link_table;

statement ok
RESET dp_sum_bound;

statement ok
SET privacy_noise = true;

# ---------------------------------------------------------------------------
# Phase G: AVG via SUM/COUNT decomposition with ε/2 budget split
# ---------------------------------------------------------------------------
# AVG(x) = noised_SUM(clipped(x)) / max(1, noised_COUNT). Each component uses
# ε/2 → combined cost is still ε-DP. Output type is DOUBLE.
# ---------------------------------------------------------------------------

# AVG requires dp_sum_bound — error if unset
statement ok
RESET dp_sum_bound;

statement error
SELECT AVG(id) FROM u;
----
dp_sum_bound

# With bound=100 (no clipping): true avg of 0..99 = 49.5; noised result close
statement ok
SET dp_sum_bound = 100.0;

query I
SELECT abs(AVG(id) - 49.5) < 1000 FROM u;
----
true

# Output type is DOUBLE (AVG always returns a floating point ratio)
query I
SELECT typeof(AVG(id)) FROM u;
----
DOUBLE

# 1-hop join AVG: amount values in 0..6, bound=10 → no clipping. True avg = 1494/500 = 2.988
statement ok
SET dp_sum_bound = 10.0;

query I
SELECT abs(AVG(amount) - 2.988) < 100 FROM u JOIN orders ON u.id = orders.uid;
----
true

# Implicit FK chain: AVG(amount) on orders without explicit join — same as the joined version
query I
SELECT abs(AVG(amount) - 2.988) < 100 FROM orders;
----
true

# ---------------------------------------------------------------------------
# Phase G: AVG deterministic tests (privacy_noise = false)
# ---------------------------------------------------------------------------

statement ok
SET privacy_noise = false;

# True avg without clipping: 0+1+...+99 / 100 = 49.5
statement ok
SET dp_sum_bound = 100.0;

query I
SELECT AVG(id) FROM u;
----
49.5

# Clipping at 40: ids 0..39 unchanged; ids 40..99 → 40 (60 rows × 40 = 2400)
# Clipped sum = 780 + 2400 = 3180; clipped avg = 3180/100 = 31.8
statement ok
SET dp_sum_bound = 40.0;

query I
SELECT AVG(id) FROM u;
----
31.8

# 1-hop join AVG: bound=10 (no clipping); true sum=1494, count=500 → avg = 2.988
statement ok
SET dp_sum_bound = 10.0;

query I
SELECT AVG(amount) FROM u JOIN orders ON u.id = orders.uid;
----
2.988

# Implicit FK chain (no explicit join) — same result
query I
SELECT AVG(amount) FROM orders;
----
2.988

# 2-hop chain AVG: 750 lines, price=(i%5)*1.0; values 0..4 ≤ bound=5 (no clipping)
# Sum = 150 * (0+1+2+3+4) = 1500; avg = 1500/750 = 2.0
statement ok
SET dp_sum_bound = 5.0;

query I
SELECT AVG(price) FROM customers2
JOIN customer_orders ON customers2.cust_id = customer_orders.cust_id
JOIN order_lines ON customer_orders.ord_id = order_lines.ord_id;
----
2.0

# Implicit FK chain (2-hop, no explicit joins) — same result
query I
SELECT AVG(price) FROM order_lines;
----
2.0

# ---------------------------------------------------------------------------
# Phase H: multi-aggregate budget split (sequential composition)
# k user-visible aggregates → each uses ε/k. With privacy_noise=false the
# rewrite still runs (clipping, k-split scale calc) but Laplace scale is 0
# so the result is exact. Runtime correctness is verified deterministically;
# noise calibration is exercised by the noisy tests in earlier phases.
# ---------------------------------------------------------------------------

# 2 aggregates: COUNT and SUM, k=2 → each uses ε/2. Exact under noise=false.
statement ok
SET dp_sum_bound = 100.0;

query II
SELECT COUNT(*), SUM(id) FROM u;
----
100	4950

# 3 aggregates: COUNT, SUM, AVG. AVG decomposes into SUM+COUNT (ε/(2·3) per
# component); other aggregates use ε/3. All exact under noise=false.
query III
SELECT COUNT(*), SUM(id), AVG(id) FROM u;
----
100	4950	49.5

# ---------------------------------------------------------------------------
# Phase I: WHERE clauses (filter pushdown is transparent to dp_elastic)
# WHERE adds a LogicalFilter between scan and aggregate; the aggregate node
# is unchanged so sensitivity, clipping, and budget split all apply on the
# filtered result. Tested under privacy_noise=false for deterministic checks.
# ---------------------------------------------------------------------------

# WHERE on PU table — count of ids 51..99 = 49
query I
SELECT COUNT(*) FROM u WHERE id > 50;
----
49

# WHERE on PU table with SUM — sum of ids 51..99 = 3675 (no clipping at bound=100)
statement ok
SET dp_sum_bound = 100.0;

query I
SELECT SUM(id) FROM u WHERE id > 50;
----
3675

# WHERE on PU table with AVG — avg of ids 51..99 = 75.0
query I
SELECT AVG(id) FROM u WHERE id > 50;
----
75.0

# WHERE with implicit FK chain (filter on orders, no explicit join to u)
# amount > 3.0 → values 4,5,6 in 7-cycle, 71 full cycles → 71*3 = 213
query I
SELECT COUNT(*) FROM orders WHERE amount > 3.0;
----
213

# WHERE with explicit join — same result as implicit
query I
SELECT COUNT(*) FROM u JOIN orders ON u.id = orders.uid WHERE amount > 3.0;
----
213

# WHERE with GROUP BY on a non-PU, non-protected column (orders.amount)
query II
SELECT CAST(amount AS INTEGER) AS g, COUNT(*) FROM orders WHERE amount > 2.0 GROUP BY g ORDER BY g;
----
3	71
4	71
5	71
6	71

# WHERE with multi-aggregate budget split
query II
SELECT COUNT(*), SUM(id) FROM u WHERE id > 50;
----
49	3675

# WHERE that filters out all rows — returns 0 (empty aggregate)
query I
SELECT COUNT(*) FROM u WHERE id > 1000;
----
0

# ---------------------------------------------------------------------------
# Phase J: HAVING with AVG aggregates — regression test
# DuckDB binds HAVING references to aggregate output columns. After our AVG→
# SUM rewrite, the AVG column is the SUM in the noise projection. The ratio
# projection must be inserted BELOW HAVING so HAVING's bindings get remapped
# from the SUM to the ratio output. Otherwise `HAVING AVG(x) > 3` would
# secretly filter on the SUM, returning wrong groups.
# ---------------------------------------------------------------------------

statement ok
SET dp_sum_bound = 10.0;

# HAVING AVG(amount) > 3: only groups with avg ∈ {4, 5, 6} survive.
# Pre-fix bug: this returned groups 1..6 because HAVING checked SUM not ratio.
query II
SELECT CAST(amount AS INTEGER) g, AVG(amount) FROM orders GROUP BY g HAVING AVG(amount) > 3 ORDER BY g;
----
4	4.0
5	5.0
6	6.0

# Combined HAVING on AVG and COUNT — both predicates apply correctly
query III
SELECT CAST(amount AS INTEGER) g, AVG(amount), COUNT(*) FROM orders
GROUP BY g HAVING AVG(amount) > 3 AND COUNT(*) > 70 ORDER BY g;
----
4	4.0	71
5	5.0	71
6	6.0	71

# FILTER (WHERE pred) on AVG: predicate must propagate to BOTH the rewritten
# SUM and the appended COUNT, otherwise the ratio uses the unfiltered count.
# amount>2 → values 3,4,5,6 → sum=1278, count=284, avg=4.5.
query I
SELECT AVG(amount) FILTER (WHERE amount > 2) FROM orders;
----
4.5

# Mixed: filtered and unfiltered AVG in the same query — must give different results
query II
SELECT AVG(amount), AVG(amount) FILTER (WHERE amount > 2) FROM orders;
----
2.988	4.5

statement ok
RESET dp_sum_bound;

statement ok
SET privacy_noise = true;

# ---------------------------------------------------------------------------
# Phase F: GROUP BY + pre-noise support threshold (privacy_min_group_count)
# ---------------------------------------------------------------------------
# orders: amount=(i%7)*1.0 → 7 groups (0..6). Support is distinct uid
# per group, computed before value noise. The internal support column is not
# returned to the user.
# ---------------------------------------------------------------------------

statement ok
SET dp_epsilon = 1.0;

statement ok
RESET dp_sum_bound;

statement ok
SET privacy_noise = false;

# Scalar aggregate: 100 PUs, so threshold 101 suppresses the single row
statement ok
SET privacy_min_group_count = 101;

query I
SELECT COUNT(*) FROM u;
----

# Threshold 100 keeps the scalar aggregate
statement ok
SET privacy_min_group_count = 100;

query I
SELECT COUNT(*) FROM u;
----
100

# Grouped FK query: each amount group has fewer than 101 distinct users, so all groups drop
statement ok
SET privacy_min_group_count = 101;

query II rowsort
SELECT CAST(amount AS INTEGER), COUNT(*) FROM orders GROUP BY CAST(amount AS INTEGER);
----

# SUM/AVG also use the same pre-noise support gate
statement ok
SET dp_sum_bound = 10.0;

query III rowsort
SELECT CAST(amount AS INTEGER), SUM(amount), AVG(amount)
FROM orders GROUP BY CAST(amount AS INTEGER);
----

# Low threshold keeps all 7 groups and does not expose the support column
statement ok
SET privacy_min_group_count = 1;

query II rowsort
SELECT CAST(amount AS INTEGER), COUNT(*) FROM orders GROUP BY CAST(amount AS INTEGER);
----
0	72
1	72
2	72
3	71
4	71
5	71
6	71

query III rowsort
SELECT CAST(amount AS INTEGER), SUM(amount), AVG(amount)
FROM orders GROUP BY CAST(amount AS INTEGER);
----
0	0.0	0.0
1	72.0	1.0
2	144.0	2.0
3	213.0	3.0
4	284.0	4.0
5	355.0	5.0
6	426.0	6.0

statement ok
RESET privacy_min_group_count;

statement ok
RESET dp_sum_bound;

statement ok
SET privacy_noise = true;
