# name: test/sql/dp_sample_median.test
# description: DP sample-median strategy using PAC-style sample counters and smooth clipping
# group: [sql]

require privacy

statement ok
PRAGMA clear_privacy_metadata;

statement ok
SET threads = 1;

statement ok
SET privacy_seed = 42;

statement ok
SET privacy_mode = 'dp_sass';

statement ok
SET privacy_noise = false;

statement ok
SET dp_epsilon = 1.0;

statement ok
SET dp_delta = 1e-6;

query I
SELECT current_setting('privacy_mode');
----
dp_sass

query I
SELECT current_setting('dp_sample_lanes');
----
1

statement error
SET dp_sample_lanes = 0;
----
dp_sample_lanes

statement error
SET dp_sample_lanes = 9;
----
dp_sample_lanes

statement ok
SET dp_sample_lanes = 1;

query II
SELECT priv_sample_sum(0::UBIGINT, 1.0)[1]::INTEGER,
       priv_sample_sum(0::UBIGINT, 1.0)[2]::INTEGER;
----
64	0

query II
SELECT priv_sample_min(0::UBIGINT, 7.0::DOUBLE)[1]::INTEGER,
       priv_sample_min(0::UBIGINT, 7.0::DOUBLE)[2] IS NULL;
----
7	true

query II
SELECT priv_sample_max(0::UBIGINT, 7.0::DOUBLE)[1]::INTEGER,
       priv_sample_max(0::UBIGINT, 7.0::DOUBLE)[2] IS NULL;
----
7	true

query II
SELECT abs(priv_sample_min(0::UBIGINT, 7.25::DECIMAL(10,2))[1] - 7.25) < 1e-5,
       priv_sample_min(0::UBIGINT, 7.25::DECIMAL(10,2))[2] IS NULL;
----
true	true

query II
SELECT priv_sample_min(0::UBIGINT, 0.0::DOUBLE)[1] = 0.0,
       priv_sample_min(0::UBIGINT, 0.0::DOUBLE)[2] IS NULL;
----
true	true

statement ok
SET dp_sample_lanes = 2;

query III
SELECT abs(priv_sample_sum(64::UBIGINT, 1.0)[1] - (4096.0 / 127.0)) < 1e-5,
       abs(priv_sample_sum(64::UBIGINT, 1.0)[2] - (4096.0 / 127.0)) < 1e-5,
       priv_sample_sum(64::UBIGINT, 1.0)[3] = 0;
----
true	true	true

statement ok
SET dp_sample_lanes = 8;

# Smooth sensitivity treats affected as a sample-aggregate step size. One PU can
# affect dp_sample_lanes sample lanes, so an eight-lane median jump must be charged
# at distance 0 here, not exponentially decayed as eight separate PU changes. The
# scalar takes sample_lanes explicitly so prepared statements and reused counters
# do not observe a later setting change.
statement ok
SET privacy_noise = true;

statement ok
SET dp_sample_lanes = 1;

query I
WITH vals AS (
    SELECT CASE WHEN i < 39 THEN 0.0::FLOAT ELSE 100000.0::FLOAT END AS v
    FROM range(64) t(i)
), counters AS (
    SELECT list(v ORDER BY v) AS l FROM vals
)
SELECT abs(priv_smooth_median_noise(l, 10.0, 1e-6, 8)) > 10000.0
FROM counters;
----
true

statement ok
SET privacy_noise = false;

query I
WITH vals AS (
    SELECT CASE WHEN i < 33 THEN NULL::FLOAT ELSE 0.0::FLOAT END AS v, i
    FROM range(64) t(i)
), counters AS (
    SELECT list(v ORDER BY i) AS l FROM vals
)
SELECT priv_smooth_median_noise(l, 1.0, 1e-6, 1) IS NULL
FROM counters;
----
true

query I
WITH vals AS (
    SELECT CASE WHEN i < 32 THEN NULL::FLOAT ELSE 0.0::FLOAT END AS v, i
    FROM range(64) t(i)
), counters AS (
    SELECT list(v ORDER BY i) AS l FROM vals
)
SELECT priv_smooth_median_noise(l, 1.0, 1e-6, 1) = 0.0
FROM counters;
----
true

query I
WITH vals AS (
    SELECT CASE WHEN i < 32 THEN NULL::FLOAT WHEN i < 48 THEN -10.0::FLOAT ELSE 10.0::FLOAT END AS v, i
    FROM range(64) t(i)
), counters AS (
    SELECT list(v ORDER BY i) AS l FROM vals
)
SELECT priv_smooth_median_noise(l, 1.0, 1e-6, 1) = 10.0
FROM counters;
----
true

statement ok
CREATE TABLE users AS SELECT i AS uid FROM range(1, 1001) t(i);

statement ok
CREATE TABLE events AS
SELECT uid,
       CASE WHEN uid % 2 = 0 THEN 'even' ELSE 'odd' END AS segment,
       1.0::DOUBLE AS v
FROM users;

statement ok
ALTER TABLE users ADD PRIVACY_KEY (uid);

statement ok
ALTER TABLE users SET PU;

statement ok
ALTER TABLE events ADD PRIVACY_LINK (uid) REFERENCES users(uid);

# COUNT uses the configured sample mask and median release. With noise disabled,
# it is deterministic but still an estimator, not the exact count.
query I
SELECT COUNT(*) BETWEEN 900 AND 1100 FROM events;
----
true

query II
SELECT segment, COUNT(*) BETWEEN 450 AND 550
FROM events
GROUP BY segment
ORDER BY segment;
----
even	true
odd	true

query I
SELECT typeof(COUNT(*)) FROM events;
----
BIGINT

# SASS SUM does not use elastic-DP value bounds or clipping support.
statement ok
RESET dp_sum_bound;

statement ok
SET priv_clip_support = 0;

query I
SELECT SUM(v) BETWEEN 900.0 AND 1100.0 FROM events;
----
true

# Parallel execution exercises aggregate combine/finalize with buffered sample hashes.
statement ok
SET threads = 4;

query I
SELECT COUNT(*) BETWEEN 900 AND 1100 FROM events;
----
true

query I
SELECT SUM(v) BETWEEN 900.0 AND 1100.0 FROM events;
----
true

statement ok
SET threads = 1;

query II
SELECT segment, SUM(v) BETWEEN 450.0 AND 550.0
FROM events
GROUP BY segment
ORDER BY segment;
----
even	true
odd	true

query I
SELECT typeof(SUM(v)) FROM events;
----
DOUBLE

# Group suppression uses the lower aggregate's one-row-per-PU shape, not per-lane support counts.
statement ok
SET privacy_min_group_count = 600;

query II
SELECT segment, COUNT(*) FROM events GROUP BY segment ORDER BY segment;
----

query II
SELECT segment, AVG(v) FROM events GROUP BY segment ORDER BY segment;
----

statement ok
SET privacy_min_group_count = NULL;

query III
SELECT COUNT(*) BETWEEN 900 AND 1100, SUM(v) BETWEEN 900.0 AND 1100.0, AVG(v) BETWEEN 0.9 AND 1.1
FROM events;
----
true	true	true

query II
SELECT segment, AVG(v) BETWEEN 0.9 AND 1.1
FROM events
GROUP BY segment
HAVING AVG(v) > 0.5
ORDER BY segment;
----
even	true
odd	true

query I
SELECT AVG(v) FILTER (WHERE uid <= 500) BETWEEN 0.9 AND 1.1 FROM events;
----
true

statement ok
SET privacy_noise = true;

query II
SELECT AVG(v) IS NOT NULL, isfinite(AVG(v)) FROM events;
----
true	true

statement ok
SET privacy_noise = false;

statement error
SELECT COUNT(DISTINCT uid) FROM events;
----
DISTINCT

query II
SELECT MIN(v) BETWEEN 0.9 AND 1.1,
       MAX(v) BETWEEN 0.9 AND 1.1
FROM events;
----
true	true

query II
SELECT typeof(MIN(v)), typeof(MAX(v)) FROM events;
----
DOUBLE	DOUBLE

# SASS AVG is decomposed into sample SUM/COUNT and does not require bounds.
statement ok
RESET dp_sum_bound;

statement ok
SET priv_clip_support = 0;

query I
SELECT AVG(v) BETWEEN 0.9 AND 1.1 FROM events;
----
true

statement ok
CREATE TABLE typed_scores AS
SELECT i AS uid,
       (i % 100)::INTEGER AS score_i,
       ((i % 100) + 0.25)::DECIMAL(10,2) AS score_dec
FROM range(1, 1001) t(i);

statement ok
ALTER TABLE typed_scores ADD PRIVACY_LINK (uid) REFERENCES users(uid);

query III
SELECT MIN(score_i) BETWEEN 0 AND 20,
       MAX(score_i) BETWEEN 80 AND 99,
       typeof(MIN(score_i))
FROM typed_scores;
----
true	true	INTEGER

query III
SELECT MIN(score_dec) BETWEEN 0.25::DECIMAL(10,2) AND 20.25::DECIMAL(10,2),
       MAX(score_dec) BETWEEN 80.25::DECIMAL(10,2) AND 99.25::DECIMAL(10,2),
       typeof(MIN(score_dec))
FROM typed_scores;
----
true	true	DECIMAL(10,2)

statement ok
CREATE TABLE non_numeric_scores AS
SELECT i AS uid,
       'name-' || i::VARCHAR AS name,
       DATE '2020-01-01' + i::INTEGER AS created_at
FROM range(1, 11) t(i);

statement ok
ALTER TABLE non_numeric_scores ADD PRIVACY_LINK (uid) REFERENCES users(uid);

statement error
SELECT MIN(name) FROM non_numeric_scores;
----
min argument must be a numeric type

statement error
SELECT MAX(created_at) FROM non_numeric_scores;
----
max argument must be a numeric type

statement ok
CREATE TABLE tiny_events(uid INTEGER, v DOUBLE);

statement ok
INSERT INTO tiny_events VALUES (1, 10.0);

statement ok
ALTER TABLE tiny_events ADD PRIVACY_LINK (uid) REFERENCES users(uid);

query IIIII
SELECT COUNT(*) = 0,
       SUM(v) = 0.0,
       AVG(v) IS NULL,
       MIN(v) IS NULL,
       MAX(v) IS NULL
FROM tiny_events;
----
true	true	true	true	true

query III
SELECT AVG(v) IS NULL,
       MIN(v) IS NULL,
       MAX(v) IS NULL
FROM tiny_events
WHERE uid > 1;
----
true	true	true

statement ok
CREATE TABLE scores AS
SELECT i AS uid,
       CASE WHEN i % 2 = 0 THEN 'even' ELSE 'odd' END AS segment,
       (i % 100)::DOUBLE AS score
FROM range(1, 1001) t(i);

statement ok
ALTER TABLE scores ADD PRIVACY_LINK (uid) REFERENCES users(uid);

query II
SELECT MIN(score) BETWEEN 0.0 AND 20.0,
       MAX(score) BETWEEN 80.0 AND 99.0
FROM scores;
----
true	true

query III
SELECT segment,
       MIN(score) BETWEEN 0.0 AND 25.0,
       MAX(score) BETWEEN 74.0 AND 99.0
FROM scores
GROUP BY segment
ORDER BY segment;
----
even	true	true
odd	true	true

statement ok
SET privacy_noise = true;

query III
SELECT MIN(score) IS NOT NULL,
       isfinite(MIN(score)),
       isfinite(MAX(score))
FROM scores;
----
true	true	true

statement ok
SET privacy_noise = false;

statement ok
CREATE TABLE clicks AS
SELECT i AS uid, i % 3 AS clicks
FROM range(1, 1001) t(i);

statement ok
ALTER TABLE clicks ADD PRIVACY_LINK (uid) REFERENCES users(uid);

statement error
SELECT COUNT(*)
FROM users
JOIN events ON users.uid = events.uid
JOIN clicks ON users.uid = clicks.uid;
----
star/diamond

statement error
SELECT COUNT(*)
FROM events e1
JOIN events e2 ON e1.uid = e2.uid;
----
self-joins

# Multi-hop chain: users2 <- orders2 <- lines2. Sample-median must reuse PAC's
# FK join insertion and PU hash propagation rather than hashing the leaf key.
statement ok
CREATE TABLE users2 AS SELECT i AS uid FROM range(1, 1001) t(i);

statement ok
CREATE TABLE orders2 AS
SELECT i AS oid, ((i - 1) % 1000) + 1 AS uid
FROM range(1, 5001) t(i);

statement ok
CREATE TABLE lines2 AS
SELECT i AS lid,
       ((i - 1) % 5000) + 1 AS oid,
       CASE WHEN i % 2 = 0 THEN 'even' ELSE 'odd' END AS segment,
       2.0::DOUBLE AS price
FROM range(1, 15001) t(i);

statement ok
ALTER TABLE users2 ADD PRIVACY_KEY (uid);

statement ok
ALTER TABLE users2 SET PU;

statement ok
ALTER TABLE orders2 ADD PRIVACY_KEY (oid);

statement ok
ALTER TABLE orders2 ADD PRIVACY_LINK (uid) REFERENCES users2(uid);

statement ok
ALTER TABLE lines2 ADD PRIVACY_LINK (oid) REFERENCES orders2(oid);

statement ok
RESET dp_sum_bound;

statement ok
SET priv_clip_support = 0;

query III
SELECT COUNT(*) BETWEEN 13000 AND 17000,
       SUM(price) BETWEEN 26000.0 AND 34000.0,
       AVG(price) BETWEEN 1.8 AND 2.2
FROM users2
JOIN orders2 ON users2.uid = orders2.uid
JOIN lines2 ON orders2.oid = lines2.oid;
----
true	true	true

query III
SELECT COUNT(*) BETWEEN 13000 AND 17000,
       SUM(price) BETWEEN 26000.0 AND 34000.0,
       AVG(price) BETWEEN 1.8 AND 2.2
FROM lines2;
----
true	true	true

query II
SELECT segment, AVG(price) BETWEEN 1.8 AND 2.2
FROM lines2
GROUP BY segment
ORDER BY segment;
----
even	true
odd	true

statement ok
SET privacy_mode = 'dp_elastic';
