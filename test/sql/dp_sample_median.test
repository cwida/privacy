SELECT i, CASE WHEN i < 40 THEN 0 ELSE i END
FROM range(200) t(i);

statement ok
ALTER TABLE sass_group_events ADD PRIVACY_LINK (uid) REFERENCES sass_group_users(uid);

# The pure-ε 'average' release needs no dp_delta — for an UNGROUPED query, which has a single
# data-independent output row and thus no partition selection.
statement ok
SET dp_sass_release = 'average';

statement ok
SET dp_delta = NULL;

query I
SELECT COUNT(*) IS NOT NULL FROM sass_group_events;
----
true

# A GROUPED query always applies DP partition selection (the released key set is data-dependent),
# which needs δ_η. So a grouped query under the pure-ε average release without dp_delta is rejected.
statement error
SELECT g, COUNT(*) FROM sass_group_events GROUP BY g;
----
dp_delta

statement ok
SET dp_delta = 1e-6;

statement ok
SELECT g, SUM(uid) FROM sass_group_events GROUP BY g;

statement ok
SET dp_sass_release = 'median';

statement ok
SET dp_delta = 1e-6;

statement ok
SET privacy_noise = false;

statement ok
SET dp_max_groups_contributed = 1;

# Grouped queries auto-apply DP partition selection (computed τ ≈ 29 at ε = 1); group 0 has 40
# distinct PUs so it survives (noise off → deterministic support ≥ τ), while the 160 singleton
# groups (1 PU each) are suppressed.
query II rowsort
SELECT g, CAST(c IS NOT NULL AS INTEGER)
FROM (
    SELECT g, COUNT(*) AS c
    FROM sass_group_events
    GROUP BY g
);
----
0	1

# τ derives from the Google-DP formula over C_u, ε_η, δ_η (Algorithm 2 SIMD-SAA^udp), so it scales
# with the privacy budget. With a tiny ε the threshold τ far exceeds group 0's 40 distinct PUs, so
# even this dense group is suppressed (noise off → deterministic support ≥ τ).
statement ok
SET dp_epsilon = 0.01;

query II rowsort
SELECT g, c
FROM (
    SELECT g, COUNT(*) AS c
    FROM sass_group_events
    GROUP BY g
);
----

statement ok
SET dp_epsilon = 1.0;

# Smoke test: the exact SmoothSensitivityMedian (Algorithm 1 + JList) bounded path
# with noise ON. The 64 lane values have a large gap just ABOVE the median (off-center),
# which the exact NRS envelope charges even though a centered window could miss it. With a
# fixed seed the released value is deterministic; we only assert it is finite (the path runs
# and produces a sane noised scalar).
statement ok
SET privacy_noise = true;

statement ok
SET privacy_seed = 42;

query I
WITH vals AS (
    SELECT CASE WHEN i < 30 THEN -5.0::FLOAT WHEN i < 34 THEN 0.0::FLOAT ELSE 500.0::FLOAT END AS v, i
    FROM range(64) t(i)
), counters AS (
    SELECT list(v ORDER BY i) AS l FROM vals
)
SELECT isfinite(dp_smooth_median_noise(l, 1.0, 1e-6, 1, -1000.0, 1000.0))
FROM counters;
----
true

# End-to-end dp_sass with noise ON: confirm SUM/COUNT run through the real plan and
# produce finite, non-null noised values via the exact bounded terminal.
query I
SELECT r IS NOT NULL AND isfinite(r::DOUBLE) FROM (SELECT SUM(v) AS r FROM sass_many);
----
true

statement ok
SET dp_count_bound = 10.0;

query I
SELECT r IS NOT NULL AND isfinite(r::DOUBLE) FROM (SELECT COUNT(*) AS r FROM sass_many);
----
true

statement ok
SET privacy_noise = false;

statement ok
SET dp_sample_lanes = 1;

query I
WITH counters AS (
    SELECT as_sample_count((64 + i)::UBIGINT) AS samples
    FROM range(64) t(i)
)
SELECT (dp_sass_stability(samples)).stddev_pop = 0.0
FROM counters;
----
true

query II
WITH counters AS (
    SELECT as_sample_count(0::UBIGINT) AS samples
)
SELECT (dp_sass_stability(samples)).valid_count,
       (dp_sass_stability(samples)).null_count
FROM counters;
----
64	0

query III
WITH counters AS (
    SELECT list(CASE WHEN i < 32 THEN NULL::FLOAT ELSE i::FLOAT END ORDER BY i) AS samples
    FROM range(64) t(i)
)
SELECT (dp_sass_stability(samples)).valid_count,
       (dp_sass_stability(samples)).null_count,
       (dp_sass_stability(samples)).stable_mad_1
FROM counters;
----
32	32	false

# --- Implicit FK path (PU table not named in FROM) — regression for stable sample lanes ---
# Before this fix, dp_sass silently mis-handled a query over a PRIVACY_LINK table that never scans the
# PU table: the stable lane key was unavailable, so SUM/COUNT returned 0 and AVG returned the empty-lane
# midpoint. The lanes are now built from the PU-adjacent linked table's FK column, so a PU's many rows
# share one lane. With a constant value the mean is exact, so the implicit result must equal the
# explicit-join result.
statement ok
SET privacy_mode = 'dp_sass';

statement ok
CREATE PU TABLE ifk_users(uid INTEGER, PRIVACY_KEY(uid));

statement ok
INSERT INTO ifk_users SELECT i FROM range(200) t(i);

statement ok
CREATE TABLE ifk_events(uid INTEGER, v DOUBLE);

statement ok
INSERT INTO ifk_events SELECT i % 200, 8.0 FROM range(2000) t(i);

statement ok
ALTER TABLE ifk_events ADD PRIVACY_LINK (uid) REFERENCES ifk_users(uid);

statement ok
SET privacy_noise = false;

statement ok
SET privacy_seed = 42;

statement ok
SET dp_sass_release = 'median';

statement ok
SET dp_delta = 1e-5;

statement ok
SET dp_sum_bound = 1000.0;

statement ok
SET dp_count_bound = 100.0;

statement ok
SET dp_sass_sum_output_bound = 100000.0;

statement ok
SET dp_sass_count_output_bound = 100000.0;

statement ok
SET dp_sass_avg_lower_bound = 0.0;

statement ok
SET dp_sass_avg_upper_bound = 10.0;

# Not broken: implicit SUM/COUNT/COUNT(DISTINCT) are populated (previously 0 from empty lanes).
query I
SELECT SUM(v) > 0 FROM ifk_events;
----
true

query I
SELECT COUNT(*) > 0 FROM ifk_events;
----
true

# COUNT(DISTINCT) shares the same lane-assignment site — also fixed for the implicit path.
query I
SELECT COUNT(DISTINCT v) > 0 FROM ifk_events;
----
true

# lane_average AVG: constant value → exact mean 8.0, and the implicit result equals the explicit join
# (previously implicit returned the empty-lane midpoint 5.0).
query I
SELECT AVG(v) FROM ifk_events;
----
8.0

query I
SELECT AVG(v) FROM ifk_events JOIN ifk_users ON ifk_events.uid = ifk_users.uid;
----
8.0

# ratio AVG: same, over the implicit FK path (previously 0.0 = noised_sum 0 / noised_count 0).
statement ok
SET dp_sass_avg_method = 'ratio';

query I
SELECT AVG(v) FROM ifk_events;
----
8.0

query I
SELECT AVG(v) FROM ifk_events JOIN ifk_users ON ifk_events.uid = ifk_users.uid;
----
8.0

statement ok
SET dp_sass_avg_method = 'lane_average';

statement ok
SET dp_sass_release = 'median';

statement ok
SET privacy_mode = 'dp_elastic';
