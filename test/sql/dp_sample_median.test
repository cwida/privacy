query I nosort explain_sass_distinct_count
EXPLAIN SELECT p_brand, p_type, p_size, COUNT(DISTINCT ps_suppkey) AS supplier_cnt
FROM _sass_partsupp JOIN _sass_part ON p_partkey = ps_partkey
GROUP BY p_brand, p_type, p_size;
----
as_sample_count_mask

query I
SELECT COUNT(*)
FROM (
    SELECT p_brand, p_type, p_size, COUNT(DISTINCT ps_suppkey) AS supplier_cnt
    FROM _sass_partsupp JOIN _sass_part ON p_partkey = ps_partkey
    GROUP BY p_brand, p_type, p_size
) q
WHERE supplier_cnt > 0;
----
2

query I
SELECT supplier_cnt
FROM (
    SELECT p_brand, p_type, p_size, COUNT(DISTINCT ps_suppkey) AS supplier_cnt
    FROM _sass_partsupp JOIN _sass_part ON p_partkey = ps_partkey
    GROUP BY p_brand, p_type, p_size
) q
WHERE p_brand = 'Brand#22';
----
1

