query I nosort explain_sass_q21_self_join
EXPLAIN SELECT l1.l_suppkey, COUNT(*) AS numwait
FROM _sass_q21_lineitem l1, _sass_q21_orders
WHERE o_orderkey = l1.l_orderkey
  AND o_orderstatus = 'F'
  AND l1.l_receiptdate > l1.l_commitdate
  AND EXISTS (
    SELECT *
    FROM _sass_q21_lineitem l2
    WHERE l2.l_orderkey = l1.l_orderkey
      AND l2.l_suppkey <> l1.l_suppkey
  )
  AND NOT EXISTS (
    SELECT *
    FROM _sass_q21_lineitem l3
    WHERE l3.l_orderkey = l1.l_orderkey
      AND l3.l_suppkey <> l1.l_suppkey
      AND l3.l_receiptdate > l3.l_commitdate
  )
GROUP BY l1.l_suppkey;
----
as_sample_sum

query I
SELECT numwait > 0
FROM (
    SELECT l1.l_suppkey, COUNT(*) AS numwait
    FROM _sass_q21_lineitem l1, _sass_q21_orders
    WHERE o_orderkey = l1.l_orderkey
      AND o_orderstatus = 'F'
      AND l1.l_receiptdate > l1.l_commitdate
      AND EXISTS (
        SELECT *
        FROM _sass_q21_lineitem l2
        WHERE l2.l_orderkey = l1.l_orderkey
          AND l2.l_suppkey <> l1.l_suppkey
      )
      AND NOT EXISTS (
        SELECT *
        FROM _sass_q21_lineitem l3
        WHERE l3.l_orderkey = l1.l_orderkey
          AND l3.l_suppkey <> l1.l_suppkey
          AND l3.l_receiptdate > l3.l_commitdate
      )
    GROUP BY l1.l_suppkey
) q;
----
true

statement error
SELECT COUNT(*)
FROM _sass_q21_lineitem a
JOIN _sass_q21_lineitem b
  ON a.l_orderkey = b.l_orderkey;
----
self-joins are only supported

