# Nested aggregates are not supported in DP modes. A query may have multiple
# aggregate expressions in one aggregate node, but not aggregate over another
# aggregate's private output.
statement error
EXPLAIN SELECT c_count, COUNT(*) AS custdist
FROM (
    SELECT c_custkey, COUNT(o_orderkey) AS c_count
    FROM _sass_q13_customer
    LEFT OUTER JOIN _sass_q13_orders
      ON c_custkey = o_custkey
     AND o_comment NOT LIKE '%special%requests%'
    GROUP BY c_custkey
) AS c_orders
GROUP BY c_count;
----
dp_sass: expected exactly one aggregate

statement error
SELECT custdist > 0
FROM (
    SELECT c_count, COUNT(*) AS custdist
    FROM (
        SELECT c_custkey, COUNT(o_orderkey) AS c_count
        FROM _sass_q13_customer
        LEFT OUTER JOIN _sass_q13_orders
          ON c_custkey = o_custkey
         AND o_comment NOT LIKE '%special%requests%'
        GROUP BY c_custkey
    ) AS c_orders
    GROUP BY c_count
) q;
----
dp_sass: expected exactly one aggregate

