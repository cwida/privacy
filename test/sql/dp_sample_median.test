statement ok
SET dp_delta = 1e-6;

# COUNT(DISTINCT) grouped queries auto-apply DP partition selection with a computed τ (there is no
# privacy_min_group_count knob). At ε = 1 the threshold τ (~29) sits below each group's distinct-PU
# support, so both groups survive (noise off → deterministic support ≥ τ).
query II rowsort
SELECT p_brand, supplier_cnt
FROM (
    SELECT p_brand, p_type, p_size, COUNT(DISTINCT ps_suppkey) AS supplier_cnt
    FROM _sass_partsupp JOIN _sass_part ON p_partkey = ps_partkey
    GROUP BY p_brand, p_type, p_size
) q;
----
Brand#11	7
Brand#22	1

# With a tiny ε the computed τ far exceeds every group's distinct-PU support, so partition
# selection suppresses all groups.
statement ok
SET dp_epsilon = 0.001;

query II rowsort
SELECT p_brand, supplier_cnt
FROM (
    SELECT p_brand, p_type, p_size, COUNT(DISTINCT ps_suppkey) AS supplier_cnt
    FROM _sass_partsupp JOIN _sass_part ON p_partkey = ps_partkey
    GROUP BY p_brand, p_type, p_size
) q;
----

statement ok
SET dp_epsilon = 1.0;

statement error
SELECT COUNT(*)
FROM _sass_partsupp JOIN _sass_part ON p_partkey = ps_partkey
WHERE ps_suppkey NOT IN (
    SELECT s_suppkey
    FROM _sass_supplier
    WHERE s_comment LIKE '%Customer%Complaints%'
);
----
dp_sass: scalar or mark subqueries are not supported by DP mechanisms

# Mixed COUNT(DISTINCT) aggregate lists use the same bounded per-PU distinct-count semantics as
# dp_standard: lower aggregation computes COUNT(DISTINCT x) per (PU, group), clips it by
# dp_count_bound, then releases the SASS sample sum.
query I nosort explain_sass_mixed_distinct_count
EXPLAIN SELECT p_brand, COUNT(DISTINCT ps_suppkey), COUNT(*)
FROM _sass_partsupp JOIN _sass_part ON p_partkey = ps_partkey
GROUP BY p_brand;
----
as_sample_sum

query III rowsort
SELECT p_brand, COUNT(DISTINCT ps_suppkey) AS supplier_cnt, COUNT(*) AS row_cnt
FROM _sass_partsupp JOIN _sass_part ON p_partkey = ps_partkey
GROUP BY p_brand;
----
Brand#11	59	59
Brand#22	59	59

