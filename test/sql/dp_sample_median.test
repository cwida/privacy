CREATE PU TABLE sass_balanced_130(uid INTEGER, PRIVACY_KEY(uid));

statement ok
INSERT INTO sass_balanced_130
SELECT i FROM range(130) t(i);

# With dp_sample_lanes=1, dp_sass assigns every PU to exactly one of the 64
# sample counters. For 130 PUs, 62 counters hold 2 PUs and 2 counters hold 3;
# the noise-free sample median is therefore 2 * 64 = 128 after rescaling.
statement ok
SET dp_sample_lanes = 1;

query I
SELECT COUNT(*) FROM sass_balanced_130;
----
128

