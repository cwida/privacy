query I nosort explain_sass_q13_nested_count
EXPLAIN SELECT c_count, COUNT(*) AS custdist
FROM (
    SELECT c_custkey, COUNT(o_orderkey) AS c_count
    FROM _sass_q13_customer
    LEFT OUTER JOIN _sass_q13_orders
      ON c_custkey = o_custkey
     AND o_comment NOT LIKE '%special%requests%'
    GROUP BY c_custkey
) AS c_orders
GROUP BY c_count;
----
as_sample_sum

query I
SELECT custdist > 0
FROM (
    SELECT c_count, COUNT(*) AS custdist
    FROM (
        SELECT c_custkey, COUNT(o_orderkey) AS c_count
        FROM _sass_q13_customer
        LEFT OUTER JOIN _sass_q13_orders
          ON c_custkey = o_custkey
         AND o_comment NOT LIKE '%special%requests%'
        GROUP BY c_custkey
    ) AS c_orders
    GROUP BY c_count
) q;
----
true

