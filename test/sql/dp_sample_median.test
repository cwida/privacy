# name: test/sql/dp_sample_median.test
# description: Sample-median helpers and bounded automatic dp_sass rewriting
# group: [sql]

require privacy

statement ok
PRAGMA clear_privacy_metadata;

statement ok
SET threads = 1;

statement ok
SET privacy_seed = 42;

statement ok
SET privacy_mode = 'dp_sass';

statement ok
SET privacy_noise = false;

statement ok
SET dp_epsilon = 1.0;

statement ok
SET dp_delta = 1e-6;

query I
SELECT current_setting('privacy_mode');
----
dp_sass

query I
SELECT current_setting('dp_sample_lanes');
----
1

statement error
SET dp_sample_lanes = 0;
----
dp_sample_lanes

statement error
SET dp_sample_lanes = 9;
----
dp_sample_lanes

statement ok
SET dp_sample_lanes = 1;

query II
SELECT as_sample_sum(0::UBIGINT, 1.0)[1]::INTEGER,
       as_sample_sum(0::UBIGINT, 1.0)[2]::INTEGER;
----
64	0

query II
SELECT as_sample_min(0::UBIGINT, 7.0::DOUBLE)[1]::INTEGER,
       as_sample_min(0::UBIGINT, 7.0::DOUBLE)[2] IS NULL;
----
7	true

query II
SELECT as_sample_max(0::UBIGINT, 7.0::DOUBLE)[1]::INTEGER,
       as_sample_max(0::UBIGINT, 7.0::DOUBLE)[2] IS NULL;
----
7	true

query II
SELECT abs(as_sample_min(0::UBIGINT, 7.25::DECIMAL(10,2))[1] - 7.25) < 1e-5,
       as_sample_min(0::UBIGINT, 7.25::DECIMAL(10,2))[2] IS NULL;
----
true	true

query II
SELECT as_sample_min(0::UBIGINT, 0.0::DOUBLE)[1] = 0.0,
       as_sample_min(0::UBIGINT, 0.0::DOUBLE)[2] IS NULL;
----
true	true

statement ok
SET dp_sample_lanes = 2;

query III
SELECT abs(as_sample_sum(64::UBIGINT, 1.0)[1] - (4096.0 / 127.0)) < 1e-5,
       abs(as_sample_sum(64::UBIGINT, 1.0)[2] - (4096.0 / 127.0)) < 1e-5,
       as_sample_sum(64::UBIGINT, 1.0)[3] = 0;
----
true	true	true

statement ok
SET dp_sample_lanes = 8;

# Smooth sensitivity treats affected as a sample-aggregate step size. One PU can
# affect dp_sample_lanes sample lanes, so an eight-lane median jump must be charged
# at distance 0 here, not exponentially decayed as eight separate PU changes. The
# scalar takes sample_lanes explicitly so prepared statements and reused counters
# do not observe a later setting change.
statement ok
SET privacy_noise = true;

statement ok
SET dp_sample_lanes = 1;

query I
WITH vals AS (
    SELECT CASE WHEN i < 39 THEN 0.0::FLOAT ELSE 100000.0::FLOAT END AS v
    FROM range(64) t(i)
), counters AS (
    SELECT list(v ORDER BY v) AS l FROM vals
)
SELECT abs(dp_smooth_median_noise(l, 10.0, 1e-6, 8)) > 10000.0
FROM counters;
----
true

statement ok
SET privacy_noise = false;

query I
WITH vals AS (
    SELECT CASE WHEN i < 31 THEN 0.0::FLOAT ELSE 100000.0::FLOAT END AS v
    FROM range(64) t(i)
), counters AS (
    SELECT list(v ORDER BY v) AS l FROM vals
)
SELECT dp_smooth_median_noise(l, 1.0, 1e-6, 1, -10.0, 10.0) = 10.0
FROM counters;
----
true

statement ok
SET privacy_noise = false;

query I
WITH vals AS (
    SELECT CASE WHEN i < 33 THEN NULL::FLOAT ELSE 0.0::FLOAT END AS v, i
    FROM range(64) t(i)
), counters AS (
    SELECT list(v ORDER BY i) AS l FROM vals
)
SELECT dp_smooth_median_noise(l, 1.0, 1e-6, 1) IS NULL
FROM counters;
----
true

query I
WITH vals AS (
    SELECT CASE WHEN i < 32 THEN NULL::FLOAT ELSE 0.0::FLOAT END AS v, i
    FROM range(64) t(i)
), counters AS (
    SELECT list(v ORDER BY i) AS l FROM vals
)
SELECT dp_smooth_median_noise(l, 1.0, 1e-6, 1) = 0.0
FROM counters;
----
true

query I
WITH vals AS (
    SELECT CASE WHEN i < 32 THEN NULL::FLOAT WHEN i < 48 THEN -10.0::FLOAT ELSE 10.0::FLOAT END AS v, i
    FROM range(64) t(i)
), counters AS (
    SELECT list(v ORDER BY i) AS l FROM vals
)
SELECT dp_smooth_median_noise(l, 1.0, 1e-6, 1) = 10.0
FROM counters;
----
true

statement ok
CREATE PU TABLE sass_users(uid INTEGER, v DOUBLE, PRIVACY_KEY(uid));

statement ok
INSERT INTO sass_users VALUES (1, 10.0), (2, 20.0), (3, 1000.0);

# Automatic dp_sass requires explicit sample-output domain bounds.
statement error
SELECT COUNT(*) FROM sass_users;
----
dp_count_bound

statement error
SELECT SUM(v) FROM sass_users;
----
dp_sum_bound

statement ok
SET dp_sum_bound = 500.0;

statement error
SELECT AVG(v) FROM sass_users;
----
dp_count_bound

statement ok
SET dp_count_bound = -1.0;

statement error
SELECT COUNT(*) FROM sass_users;
----
dp_count_bound

statement ok
SET dp_count_bound = 10.0;

query I
SELECT COUNT(*) IS NOT NULL FROM sass_users;
----
true

query I
SELECT SUM(v) IS NOT NULL FROM sass_users;
----
true

query I
SELECT AVG(v) IS NULL FROM sass_users;
----
true

statement ok
CREATE PU TABLE sass_many(uid INTEGER, v DOUBLE, PRIVACY_KEY(uid));

statement ok
INSERT INTO sass_many
SELECT i, i::DOUBLE FROM range(200) t(i);

query I
SELECT MIN(v) IS NOT NULL FROM sass_many;
----
true

query I
SELECT MAX(v) IS NOT NULL FROM sass_many;
----
true

query I
SELECT AVG(v) IS NOT NULL FROM sass_many;
----
true

# Smoke test: the exact SmoothSensitivityMedian (Algorithm 1 + JList) bounded path
# with noise ON. The 64 lane values have a large gap just ABOVE the median (off-center),
# which the exact NRS envelope charges even though a centered window could miss it. With a
# fixed seed the released value is deterministic; we only assert it is finite (the path runs
# and produces a sane noised scalar).
statement ok
SET privacy_noise = true;

statement ok
SET privacy_seed = 42;

query I
WITH vals AS (
    SELECT CASE WHEN i < 30 THEN -5.0::FLOAT WHEN i < 34 THEN 0.0::FLOAT ELSE 500.0::FLOAT END AS v, i
    FROM range(64) t(i)
), counters AS (
    SELECT list(v ORDER BY i) AS l FROM vals
)
SELECT isfinite(dp_smooth_median_noise(l, 1.0, 1e-6, 1, -1000.0, 1000.0))
FROM counters;
----
true

# End-to-end dp_sass with noise ON: confirm SUM/COUNT run through the real plan and
# produce finite, non-null noised values via the exact bounded terminal.
query I
SELECT r IS NOT NULL AND isfinite(r::DOUBLE) FROM (SELECT SUM(v) AS r FROM sass_many);
----
true

query I
SELECT r IS NOT NULL AND isfinite(r::DOUBLE) FROM (SELECT COUNT(*) AS r FROM sass_many);
----
true

statement ok
SET privacy_noise = false;

statement ok
SET privacy_mode = 'dp_elastic';
