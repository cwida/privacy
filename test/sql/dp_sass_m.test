statement ok
CREATE TABLE sass_m_null_cap_distinct AS
WITH lane_users AS (
    SELECT uid
    FROM (
        SELECT i::INTEGER AS uid,
               row_number() OVER (PARTITION BY (hash(i::INTEGER) & 127) ORDER BY i) AS rn
        FROM range(200000) t(i)
    ) q
    WHERE rn = 1
)
SELECT uid, marker
FROM lane_users, (VALUES (NULL::INTEGER), (892109::INTEGER)) markers(marker);

statement ok
ALTER TABLE sass_m_null_cap_distinct ADD PRIVACY_KEY (uid);

statement ok
ALTER TABLE sass_m_null_cap_distinct SET PU;

query I
SELECT COUNT(DISTINCT marker)::INTEGER FROM sass_m_null_cap_distinct;
----
1

statement ok
CREATE TABLE sass_m_repeated_distinct AS
WITH candidates AS (
    SELECT i::INTEGER AS uid,
           (i % 5)::INTEGER AS marker,
           row_number() OVER (
               PARTITION BY (hash(i::INTEGER) & 127), (i % 5)
               ORDER BY i
           ) AS rn
    FROM range(200000) t(i)
)
SELECT uid, marker
FROM candidates
WHERE rn = 1;

statement ok
ALTER TABLE sass_m_repeated_distinct ADD PRIVACY_KEY (uid);

statement ok
ALTER TABLE sass_m_repeated_distinct SET PU;

query I
SELECT COUNT(DISTINCT marker)::INTEGER FROM sass_m_repeated_distinct;
