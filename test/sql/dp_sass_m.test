statement ok
CREATE TABLE sass_m_capped_distinct AS
WITH lane_users AS (
    SELECT uid, lane
    FROM (
        SELECT i::INTEGER AS uid,
               (hash(i::INTEGER) & 127) AS lane,
               row_number() OVER (PARTITION BY (hash(i::INTEGER) & 127) ORDER BY i) AS rn
        FROM range(200000) t(i)
    ) q
    WHERE rn = 1
)
SELECT uid, marker::INTEGER AS marker
FROM lane_users, range(5) t(marker);

statement ok
ALTER TABLE sass_m_capped_distinct ADD PRIVACY_KEY (uid);

statement ok
ALTER TABLE sass_m_capped_distinct SET PU;

query II
SELECT COUNT(DISTINCT marker)::INTEGER, COUNT(*)::INTEGER FROM sass_m_capped_distinct;
----
2	256

statement ok
CREATE TABLE sass_m_complex_pu AS
WITH candidates AS (
    SELECT i::INTEGER AS uid,
           (hash(i::INTEGER) & 127) AS lane,
           row_number() OVER (PARTITION BY (hash(i::INTEGER) & 127) ORDER BY i) AS rn
    FROM range(200000) t(i)
)
SELECT uid,
       CASE WHEN rn = 1 THEN 'a' ELSE 'b' END AS cohort
FROM candidates
WHERE rn <= 2;

statement ok
ALTER TABLE sass_m_complex_pu ADD PRIVACY_KEY (uid);

statement ok
ALTER TABLE sass_m_complex_pu SET PU;

statement ok
CREATE TABLE sass_m_complex_facts AS
SELECT uid, cohort, marker::INTEGER AS marker
FROM sass_m_complex_pu, range(5) t(marker)
UNION ALL
SELECT uid, cohort, NULL::INTEGER AS marker
FROM sass_m_complex_pu;

statement ok
ALTER TABLE sass_m_complex_facts ADD PRIVACY_LINK (uid) REFERENCES sass_m_complex_pu (uid);

query TII
SELECT cohort, COUNT(DISTINCT marker)::INTEGER, COUNT(*)::INTEGER
FROM sass_m_complex_facts
GROUP BY cohort
ORDER BY cohort;
----
a	2	256
b	2	256

