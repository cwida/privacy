statement ok
CREATE TABLE sass_m_complex_events AS
SELECT uid,
       CASE WHEN uid % 2 = 0 THEN 'even' ELSE 'odd' END AS category,
       marker::INTEGER AS marker,
       (marker + 1)::DOUBLE AS amount
FROM range(128) u(uid), range(2) m(marker);

statement ok
ALTER TABLE sass_m_complex_events ADD PRIVACY_LINK (uid) REFERENCES sass_m_users (uid);

query TII
SELECT category,
       COUNT(*) FILTER (WHERE marker = 1)::INTEGER AS selected_count,
       SUM(amount)::INTEGER AS sum_amount
FROM sass_m_complex_events JOIN sass_m_users USING (uid)
GROUP BY category
ORDER BY category;
----
even	64	192
odd	64	192

statement ok
SET dp_count_bound = 1;

statement ok
